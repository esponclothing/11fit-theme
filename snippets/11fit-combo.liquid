{% assign price_per_item = combo_price | divided_by: combo_count %}
{% assign regular_total_cents = product.price | times: combo_count %}
{% assign regular_total = regular_total_cents | divided_by: 100.0 %}
{% assign total_saved = regular_total | minus: combo_price %}

<div class="fit11-offer-card" style="margin: 16px 0; width: 100%; min-width: 100%; border-color: #ffdf00; cursor: default; flex-direction: column; padding: 16px;">
  <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
    <div class="fit11-offer-code" style="font-size: 14px; font-weight: 600; color: #1a202c;">{{ combo_count }} COMBO OFFER</div>
    <div style="background: #198754; color: #fff; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 700; text-transform: uppercase;">Deal Applied</div>
  </div>
  <div class="fit11-offer-desc" style="font-size: 13px; color: #1a202c; font-weight: 500; margin-top: 4px;">
    {{ combo_count }} {{ product.title | escape }} at <span style="color: #198754; font-weight: 700;">Rs.{{ price_per_item | round }} Each</span>
  </div>
  <div class="fit11-offer-desc" style="font-weight: 600; color: #d9480f; margin-top: 6px; font-size: 13px;">
    <i class="ti ti-flame"></i> You Saved ₹{{ total_saved | round }} Instantly!
  </div>
  <div style="border-top: 1px dashed #cbd5e0; margin-top: 12px; padding-top: 10px; display: flex; justify-content: space-between; font-size: 11px; font-weight: 500; color: #718096;">
    <span style="color: #198754; display: flex; align-items: center; gap: 4px;"><i class="ti ti-truck"></i> Free Delivery</span>
    <span>No Coupon Needed</span>
  </div>
</div>

<div style="background: #e6efff; border-radius: 4px; padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">
  <span style="font-size: 13px; font-weight: 500; color: #1a1a1a;">Additional Prepaid Discount At Checkout</span>
  <div style="display: flex; gap: 6px; align-items: center;">
    <img src="https://cdn.shopify.com/s/files/1/0805/0196/5080/files/PhonePe_Logo.svg?v=1718017004" onerror="this.style.display='none'" alt="PhonePe" style="height: 18px;">
    <img src="https://cdn.shopify.com/s/files/1/0805/0196/5080/files/Google_Pay_Logo.svg?v=1718017004" onerror="this.style.display='none'" alt="GPay" style="height: 18px;">
    <img src="https://cdn.shopify.com/s/files/1/0805/0196/5080/files/Paytm_Logo.svg?v=1718017004" onerror="this.style.display='none'" alt="Paytm" style="height: 18px;">
  </div>
</div>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
  <div style="font-weight: 600; font-size: 15px; color: #1a1a1a;">Select Combo</div>
  <div onclick="fit11ToggleModal(true)" style="font-size: 13px; font-weight: 500; color: #1a1a1a; cursor: pointer; display: flex; align-items: center; gap: 4px;">Size Guide <i class="ti ti-chevron-right" style="font-size: 12px;"></i></div>
</div>

<div class="fit11-combo-selectors" style="display: flex; flex-direction: column; gap: 20px; margin-bottom: 24px;">
  {% for i in (1..combo_count) %}
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
      <!-- Color Select -->
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <label style="font-size: 14px; font-weight: 500; color: #1a1a1a; margin: 0;">Color {{ i }}</label>
        <div style="position: relative;">
          <select id="combo-color-{{ i }}" class="combo-select combo-color-select" data-item="{{ i }}" data-option="color" onchange="updateComboSelection({{ i }}, 'color', this.value)" style="width: 100%; appearance: none; -webkit-appearance: none; padding: 12px 14px; border: 1px solid #d0d0d0; border-radius: 4px; font-size: 14px; color: #1a1a1a; background: #fff; outline: none; cursor: pointer; font-family: inherit;">
            <option value="" disabled selected>Select</option>
            {% for option in product.options_with_values %}
              {% assign option_name_lower = option.name | downcase %}
              {% if option_name_lower contains 'color' or option_name_lower contains 'colour' %}
                {% for value in option.values %}
                  <option value="{{ value | escape }}">{{ value }}</option>
                {% endfor %}
              {% endif %}
            {% endfor %}
          </select>
          <svg style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); pointer-events: none;" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 1L5 5L9 1" stroke="#666666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
      
      <!-- Size Select -->
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <label style="font-size: 14px; font-weight: 500; color: #1a1a1a; margin: 0;">Size {{ i }}</label>
        <div style="position: relative;">
          <select id="combo-size-{{ i }}" class="combo-select combo-size-select" data-item="{{ i }}" data-option="size" onchange="updateComboSelection({{ i }}, 'size', this.value)" style="width: 100%; appearance: none; -webkit-appearance: none; padding: 12px 14px; border: 1px solid #d0d0d0; border-radius: 4px; font-size: 14px; color: #1a1a1a; background: #fff; outline: none; cursor: pointer; font-family: inherit;">
            <option value="" disabled selected>Select</option>
            {% for option in product.options_with_values %}
              {% assign option_name_lower = option.name | downcase %}
              {% if option_name_lower contains 'size' %}
                {% for value in option.values %}
                  <option value="{{ value | escape }}">{{ value }}</option>
                {% endfor %}
              {% endif %}
            {% endfor %}
          </select>
          <svg style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); pointer-events: none;" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 1L5 5L9 1" stroke="#666666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </div>
  {% endfor %}
</div>

<div class="fit11-main-buttons-container">
  <button type="button" class="fit11-btn-cart" id="fit11ComboAddToCartBtn" style="flex: 1; margin: 0 !important; background: #222 !important; color: #fff !important; border-radius: 6px; border: none; font-weight: 600; font-size: 14px; height: 50px !important; display: flex; align-items: center; justify-content: center; gap: 8px;" onclick="addComboToCart(false)" disabled>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
    <span class="fit11-btn-text">ADD TO CART</span>
  </button>
  <button type="button" class="fit11-btn-cart" id="fit11ComboBuyNowBtn" style="flex: 1; margin: 0 !important; background: #ffdf00 !important; color: #000 !important; border-radius: 6px; border: none; font-weight: 700; font-size: 14px; height: 50px !important; display: flex; align-items: center; justify-content: center;" onclick="addComboToCart(true)" disabled>
    <span class="fit11-btn-text">BUY NOW</span>
  </button>
</div>
<div class="fit11-original-buttons-anchor"></div>

<script>
  let comboSelections = {};

  window.updateComboSelection = function(itemIndex, optionType, value) {
    if (!comboSelections[itemIndex]) {
      comboSelections[itemIndex] = {};
    }
    comboSelections[itemIndex][optionType] = value;
    validateCombo();
  };

  function validateCombo() {
    let allValid = true;
    let variantsDataEl = document.getElementById('ProductVariantsData');
    if(!variantsDataEl) return false;
    let variants = JSON.parse(variantsDataEl.textContent);
    
    const requiredCount = {{ combo_count }};
    
    for (let i = 1; i <= requiredCount; i++) {
      const sel = comboSelections[i];
      if(!sel || !sel.color || !sel.size) {
        allValid = false;
        break;
      }
      
      let matchedVariant = variants.find(v => {
        return v.options.includes(sel.color) && v.options.includes(sel.size);
      });

      if (matchedVariant) {
        comboSelections[i].variantId = matchedVariant.id;
      } else {
        allValid = false;
      }
    }

    const addBtn = document.getElementById('fit11ComboAddToCartBtn');
    const buyBtn = document.getElementById('fit11ComboBuyNowBtn');
    const stickyAddBtn = document.getElementById('fit11StickyAddBtn');
    const stickyBuyBtn = document.getElementById('fit11StickyBuyBtn');
    
    if(addBtn) {
      if (allValid) {
        addBtn.disabled = false;
        buyBtn.disabled = false;
        addBtn.style.opacity = '1'; buyBtn.style.opacity = '1';
        if(stickyAddBtn) { stickyAddBtn.disabled = false; stickyAddBtn.style.opacity = '1'; }
        if(stickyBuyBtn) { stickyBuyBtn.disabled = false; stickyBuyBtn.style.opacity = '1'; }
      } else {
        addBtn.disabled = true;
        buyBtn.disabled = true;
        addBtn.style.opacity = '0.5'; buyBtn.style.opacity = '0.5';
        if(stickyAddBtn) { stickyAddBtn.disabled = true; stickyAddBtn.style.opacity = '0.5'; }
        if(stickyBuyBtn) { stickyBuyBtn.disabled = true; stickyBuyBtn.style.opacity = '0.5'; }
      }
    }
    return allValid;
  }

  window.addComboToCart = function(isBuyNow) {
    if (!validateCombo()) return;

    const addBtn = document.getElementById('fit11ComboAddToCartBtn');
    const buyBtn = document.getElementById('fit11ComboBuyNowBtn');
    if(addBtn) {
      const origText = isBuyNow ? buyBtn.querySelector('.fit11-btn-text').innerText : addBtn.querySelector('.fit11-btn-text').innerText;
      if(isBuyNow) buyBtn.querySelector('.fit11-btn-text').innerText = 'PROCESSING...';
      else addBtn.querySelector('.fit11-btn-text').innerText = 'ADDING...';
      addBtn.disabled = true;
      buyBtn.disabled = true;
      
      const comboGroupId = Date.now().toString();
      const count = {{ combo_count }};
      const itemsToAdd = [];

      for (let i = 1; i <= count; i++) {
        itemsToAdd.push({
          id: comboSelections[i].variantId,
          quantity: 1,
          properties: {
            '_combo_id': comboGroupId,
            '_combo_required_count': count.toString(),
            '_combo_product_id': '{{ product.id }}'
          }
        });
      }

      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: itemsToAdd })
      })
      .then(response => response.json())
      .then(data => {
        const discountCode = '11FIT-COMBO-{{ product.id }}-{{ combo_count }}';
        const destination = isBuyNow ? '/checkout' : '/cart';
        // Apply discount to session silently, then redirect to cart/checkout
        fetch('/discount/' + discountCode, { redirect: 'manual' })
          .catch(() => {})
          .finally(() => {
            window.location.href = destination;
          });
      })
      .catch((error) => {
        console.error('Error:', error);
        addBtn.querySelector('.fit11-btn-text').innerText = 'ERROR';
        setTimeout(() => {
          if (isBuyNow) buyBtn.querySelector('.fit11-btn-text').innerText = origText;
          else addBtn.querySelector('.fit11-btn-text').innerText = origText;
          addBtn.disabled = false;
          buyBtn.disabled = false;
        }, 2000);
      });
    }
  }
  
  // On page load, read any pre-filled dropdown values (e.g. browser back navigation)
  // and populate comboSelections so buttons enable correctly.
  function initComboSelectionsFromDOM() {
    document.querySelectorAll('.combo-select').forEach(function(sel) {
      const itemIndex = parseInt(sel.dataset.item);
      const optionType = sel.dataset.option;
      if (sel.value && sel.value !== '') {
        if (!comboSelections[itemIndex]) comboSelections[itemIndex] = {};
        comboSelections[itemIndex][optionType] = sel.value;
      }
    });
    validateCombo();
  }

  document.addEventListener('DOMContentLoaded', initComboSelectionsFromDOM);

  // Also handle bfcache (browser back/forward) which doesn't re-fire DOMContentLoaded
  window.addEventListener('pageshow', function(event) {
    // Reset and re-read from DOM on every page show
    comboSelections = {};
    initComboSelectionsFromDOM();
  });
</script>
