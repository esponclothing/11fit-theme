  // ── PINCODE LOOKUP ──
  async function waLookupPincode(pin) {
    const spinner = document.getElementById('wa-pin-spinner');
    const statusEl = document.getElementById('wa-pin-status');
    const errEl = document.getElementById('wa-pin-error');
    spinner.style.display = 'inline';
    statusEl.innerText = '';
    errEl.style.display = 'none';
    
    const stateEl = document.getElementById('wa-addr-state');
    const districtEl = document.getElementById('wa-addr-district');
    const cityInputEl = document.getElementById('wa-addr-city-input');
    const citySelectWrap = document.getElementById('wa-city-select-wrapper');
    const citySelect = document.getElementById('wa-addr-city-select');

    try {
      const res = await fetch(`https://api.postalpincode.in/pincode/${pin}`);
      const data = await res.json();
      if (data && data[0] && data[0].Status === 'Success') {
        const postOffices = data[0].PostOffice;
        const firstPo = postOffices[0];
        
        // Lock district & state
        districtEl.value = firstPo.District || '';
        stateEl.value = firstPo.State || '';
        districtEl.readOnly = true;
        stateEl.readOnly = true;
        districtEl.style.background = '#f8fafc';
        stateEl.style.background = '#f8fafc';
        districtEl.style.cursor = 'not-allowed';
        stateEl.style.cursor = 'not-allowed';

        // Populate city dropdown
        citySelect.innerHTML = '';
        const uniqueCities = [...new Set(postOffices.map(po => po.Name))];
        uniqueCities.forEach(city => {
          const opt = document.createElement('option');
          opt.value = city;
          opt.text = city;
          citySelect.appendChild(opt);
        });

        cityInputEl.value = uniqueCities[0];
        cityInputEl.style.display = 'none';
        citySelectWrap.style.display = 'block';

        statusEl.innerHTML = '<span style="color:#16a34a;font-weight:600;">✓ Location found</span>';
      } else {
        throw new Error('PIN not found');
      }
    } catch(e) {
      // Unlock on failure
      districtEl.readOnly = false;
      stateEl.readOnly = false;
      districtEl.style.background = '#fff';
      stateEl.style.background = '#fff';
      districtEl.style.cursor = 'text';
      stateEl.style.cursor = 'text';
      
      citySelectWrap.style.display = 'none';
      cityInputEl.style.display = 'block';

      errEl.innerText = 'Could not auto-fill from PIN. Please fill manually.';
      errEl.style.display = 'block';
      statusEl.innerHTML = '<span style="color:#f59e0b;">Enter manually below</span>';
    } finally {
      spinner.style.display = 'none';
    }
  }

