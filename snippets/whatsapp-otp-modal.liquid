  async function calculateCheckoutTotals(discountCode = null) {
    document.getElementById('wa-subtotal').innerText = 'Calculating...';
    document.getElementById('wa-total').innerText = '...';
    try {
      const cartRes = await fetch('/cart.js');
      const cart = await cartRes.json();
      const items = cart.items.map(i => ({ variant_id: i.variant_id, quantity: i.quantity }));
      const res = await fetch(`${WA_API_BASE}/checkout/calculate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          merchant_key: MERCHANT_KEY, 
          items, 
          discount_code: discountCode,
          cart_discount: cart.total_discount || 0,
          cart_subtotal: cart.original_total_price || 0,
          phone: waPhone || null,
          device_id: localStorage.getItem('fit11_device_id') || localStorage.getItem('wa_device_id') || null,
          raw_cart: cart
        })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed to calculate');

      waDraftOrderId = data.draft_order_id;
      waInvoiceUrl = data.invoice_url;
      waAppliedDiscountCode = discountCode;
      
      document.getElementById('wa-subtotal').innerText = `₹${parseFloat(data.subtotal).toFixed(2)}`;
      document.getElementById('wa-total').innerText = `₹${parseFloat(data.total_price).toFixed(2)}`;
      document.getElementById('wa-total').setAttribute('data-base-total', parseFloat(data.total_price).toFixed(2));

      const summaryContainer = document.querySelector('.wa-order-summary');
      
      // Rebuild summary to include discount row if present
      let discountHtml = '';
      if (data.discount_amount && parseFloat(data.discount_amount) > 0) {
        let discountTitle = data.discount_title || 'Discount';
        discountHtml = `
          <div class="wa-summary-row" style="color:#16a34a; align-items:center;">
            <span>${discountTitle} ${discountCode ? `<button onclick="waRemoveCoupon()" style="background:none;border:none;color:#ef4444;font-size:11px;font-weight:600;margin-left:6px;cursor:pointer;">✕ Remove</button>` : ''}</span>
            <span>-₹${parseFloat(data.discount_amount).toFixed(2)}</span>
          </div>
        `;
      }
      
      summaryContainer.innerHTML = `
        <div class="wa-summary-title">Order Summary</div>
        <div class="wa-summary-row">
          <span>Subtotal (MRP)</span>
          <span id="wa-subtotal" style="font-weight:600; color:#0f172a;">₹${(parseFloat(data.subtotal) + (data.discount_amount ? parseFloat(data.discount_amount) : 0)).toFixed(2)}</span>
        </div>
        ${discountHtml}
        <div class="wa-summary-row">
          <span>Shipping</span>
          <span class="wa-free-label">FREE</span>
        </div>
        <div class="wa-summary-row total">
          <span>Total</span>
          <span id="wa-total" data-base-total="${parseFloat(data.total_price).toFixed(2)}">₹${parseFloat(data.total_price).toFixed(2)}</span>
        </div>
      `;
      
      waPaymentSettings = data.payment_settings || {};
      if (document.getElementById('wa-step-4').style.display === 'block') {
          renderPaymentMethods();
      }

    } catch (e) {
      if (discountCode && String(e.message) === 'invalid_discount') {
        alert('The discount code entered is invalid or expired.');
        waAppliedDiscountCode = null;
        calculateCheckoutTotals(); // Recalculate without code
      } else {
        // Fallback: read from cart
        try {
          const cartRes = await fetch('/cart.js');
          const cart = await cartRes.json();
          const total = (cart.total_price / 100).toFixed(0);
          document.getElementById('wa-subtotal').innerText = `₹${total}`;
          document.getElementById('wa-total').innerText = `₹${total}`;
          document.getElementById('wa-total').setAttribute('data-base-total', total);
        } catch(e2) {
          document.getElementById('wa-subtotal').innerText = 'See cart';
          document.getElementById('wa-total').innerText = 'See cart';
        }
      }
    }
  }

  async function waApplyCoupon() {
    const code = document.getElementById('wa-coupon-code').value.trim();
    if (!code) return;
    const btn = document.querySelector('.wa-coupon-apply');
    const originalText = btn.innerText;
    btn.innerText = '...';
    await calculateCheckoutTotals(code);
    if (waAppliedDiscountCode === code) {
      btn.innerText = 'Applied ✓';
      btn.style.backgroundColor = '#16a34a';
      btn.style.color = '#fff';
      btn.style.borderColor = '#16a34a';
    } else {
      btn.innerText = originalText;
    }
  }

  async function waRemoveCoupon() {
    waAppliedDiscountCode = null;
    document.getElementById('wa-coupon-code').value = '';
    const btn = document.querySelector('.wa-coupon-apply');
    btn.innerText = 'Apply';
    btn.style.backgroundColor = '#f1f5f9';
    btn.style.color = '#0f172a';
    btn.style.borderColor = '#e2e8f0';
    await calculateCheckoutTotals();
