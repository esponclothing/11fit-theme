        html += `
          <div class="wa-address-card" style="padding:16px;">
            <div style="display:flex; justify-content:space-between; align-items:flex-start;">
              <div style="cursor:pointer; flex:1;" onclick="waSelectAddress('${a.id}')">
                <div class="wa-addr-name">${a.first_name} ${a.last_name}</div>
                <div class="wa-addr-text">${a.address1}<br/>${a.city} - ${a.zip}</div>
                ${a.company ? `<div class="wa-addr-text" style="color:#94a3b8;">${a.company}</div>` : ''}
                
                <div style="display:flex;gap:12px;margin-top:10px;">
                  ${!a.id.toString().startsWith('shopify_') ? `<button onclick="waEditAddress('${a.id}')" style="background:none;border:none;color:#3b82f6;font-size:13px;font-weight:600;cursor:pointer;padding:0;text-decoration:none;">Edit</button>` : ''}
                  <button onclick="waDeleteAddress('${a.id}')" style="background:none;border:none;color:#ef4444;font-size:13px;font-weight:600;cursor:pointer;padding:0;text-decoration:none;">Delete</button>
