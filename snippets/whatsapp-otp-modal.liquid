{% style %}
  #wa-otp-overlay * { box-sizing: border-box; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }

  #wa-otp-overlay {
    position: fixed !important; top: 0 !important; left: 0 !important;
    width: 100vw !important; height: 100vh !important;
    z-index: 2147483647 !important; display: none;
    overflow-y: auto !important;
    background: rgba(15, 23, 42, 0.6) !important;
    backdrop-filter: blur(6px) !important;
    -webkit-backdrop-filter: blur(6px) !important;
    align-items: flex-start !important;
    justify-content: center !important;
    padding: 0 !important;
  }

  /* ── MAIN WRAPPER ── */
  .wa-checkout-wrapper {
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: stretch;
  }

  /* ── LEFT PANEL (desktop only) ── */
  .wa-left-panel {
    display: none;
    width: 380px;
    min-width: 380px;
    background: linear-gradient(145deg, #0f172a 0%, #1e293b 50%, #0f4c75 100%);
    padding: 50px 40px;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
  }
  .wa-left-panel::before {
    content: '';
    position: absolute; top: -80px; right: -80px;
    width: 300px; height: 300px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
  }
  .wa-left-panel::after {
    content: '';
    position: absolute; bottom: -60px; left: -60px;
    width: 250px; height: 250px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
  }
  .wa-brand-name {
    font-size: 32px; font-weight: 800; color: #fff;
    letter-spacing: -1px; margin-bottom: 6px;
  }
  .wa-brand-tagline {
    font-size: 14px; color: rgba(255,255,255,0.5); font-weight: 400;
    display: flex; align-items: center; gap: 6px;
  }
  .wa-brand-tagline svg { width: 14px; height: 14px; }
  .wa-trust-badges { margin-top: 60px; display: flex; flex-direction: column; gap: 20px; }
  .wa-trust-item {
    display: flex; align-items: center; gap: 14px;
    color: rgba(255,255,255,0.8); font-size: 14px; font-weight: 500;
  }
  .wa-trust-icon {
    width: 42px; height: 42px; border-radius: 10px;
    background: rgba(255,255,255,0.08);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
  }
  .wa-left-footer { font-size: 12px; color: rgba(255,255,255,0.3); }

  /* ── RIGHT PANEL ── */
  .wa-right-panel {
    flex: 1;
    background: #fff;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    max-width: 100%;
  }

  /* ── HEADER ── */
  .wa-modal-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 28px;
    border-bottom: 1px solid #f1f5f9;
    position: sticky; top: 0; background: #fff; z-index: 10;
  }
  .wa-mobile-brand { display: flex; align-items: center; gap: 10px; }
  .wa-mobile-logo-text {
    font-size: 20px; font-weight: 800; color: #0f172a; letter-spacing: -0.5px;
  }
  .wa-secure-badge {
    display: flex; align-items: center; gap: 5px;
    font-size: 11px; color: #64748b; font-weight: 500;
    background: #f8fafc; border: 1px solid #e2e8f0;
    padding: 4px 10px; border-radius: 20px;
  }
  .wa-secure-badge svg { width: 11px; height: 11px; color: #16a34a; }
  .wa-close-btn {
    width: 36px; height: 36px; border-radius: 50%;
    background: #f1f5f9; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; color: #64748b;
    transition: all 0.2s; flex-shrink: 0;
  }
  .wa-close-btn:hover { background: #e2e8f0; color: #0f172a; }

  /* ── CONTENT AREA ── */
  .wa-content-area {
    flex: 1; padding: 36px 28px;
    max-width: 520px; width: 100%; margin: 0 auto;
  }

  /* ── STEP INDICATOR ── */
  .wa-steps {
    display: flex; align-items: center; gap: 0;
    margin-bottom: 36px;
  }
  .wa-step-dot {
    width: 28px; height: 28px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700;
    background: #f1f5f9; color: #94a3b8;
    flex-shrink: 0; transition: all 0.3s;
  }
  .wa-step-dot.active { background: #0f172a; color: #fff; }
  .wa-step-dot.done { background: #16a34a; color: #fff; }
  .wa-step-line {
    flex: 1; height: 2px; background: #e2e8f0; transition: background 0.3s;
  }
  .wa-step-line.done { background: #16a34a; }

  /* ── SECTION TITLE ── */
  .wa-section-eyebrow {
    font-size: 11px; font-weight: 600; color: #3b82f6;
    text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px;
  }
  .wa-section-title {
    font-size: 24px; font-weight: 800; color: #0f172a;
    margin: 0 0 6px 0; letter-spacing: -0.5px; line-height: 1.2;
  }
  .wa-section-desc {
    font-size: 14px; color: #64748b; margin: 0 0 28px 0; line-height: 1.5;
  }

  /* ── FORM ── */
  .wa-field-group { margin-bottom: 16px; }
  .wa-field-label {
    font-size: 12px; font-weight: 600; color: #374151;
    display: block; margin-bottom: 6px; letter-spacing: 0.3px;
  }
  .wa-input {
    width: 100%; padding: 13px 16px;
    border: 1.5px solid #e2e8f0; border-radius: 10px;
    font-size: 15px; background: #fff; color: #0f172a;
    transition: all 0.2s; outline: none;
  }
  .wa-input:focus { border-color: #0f172a; box-shadow: 0 0 0 3px rgba(15,23,42,0.06); }
  .wa-input::placeholder { color: #cbd5e1; }

  /* Phone row with +91 */
  .wa-phone-row { display: flex; gap: 0; }
  .wa-phone-prefix {
    padding: 13px 14px; background: #f8fafc;
    border: 1.5px solid #e2e8f0; border-right: none;
    border-radius: 10px 0 0 10px;
    font-size: 14px; font-weight: 600; color: #374151;
    white-space: nowrap; display: flex; align-items: center; gap: 6px;
  }
  .wa-phone-row .wa-input { border-radius: 0 10px 10px 0; }

  /* OTP input boxes */
  .wa-otp-boxes { display: flex; gap: 12px; justify-content: center; margin: 8px 0; }
  .wa-otp-box {
    width: 64px; height: 64px; border: 1.5px solid #e2e8f0;
    border-radius: 12px; text-align: center; font-size: 24px; font-weight: 700;
    color: #0f172a; outline: none; transition: all 0.2s;
  }
  .wa-otp-box:focus { border-color: #0f172a; box-shadow: 0 0 0 3px rgba(15,23,42,0.06); }

  /* ── BUTTON ── */
  .wa-btn-primary {
    width: 100%; padding: 15px;
    background: #0f172a; color: #fff;
    border: none; border-radius: 10px;
    font-size: 15px; font-weight: 700; cursor: pointer;
    transition: all 0.2s; display: flex; align-items: center;
    justify-content: center; gap: 8px; letter-spacing: 0.2px;
  }
  .wa-btn-primary:hover { background: #1e293b; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(15,23,42,0.2); }
  .wa-btn-primary:active { transform: translateY(0); }
  .wa-btn-primary:disabled { background: #cbd5e1; cursor: not-allowed; transform: none; box-shadow: none; }
  .wa-btn-primary.loading { pointer-events: none; }

  .wa-btn-secondary {
    width: 100%; padding: 14px;
    background: transparent; color: #475569;
    border: 1.5px solid #e2e8f0; border-radius: 10px;
    font-size: 14px; font-weight: 600; cursor: pointer;
    transition: all 0.2s; margin-top: 10px;
  }
  .wa-btn-secondary:hover { border-color: #cbd5e1; background: #f8fafc; }

  /* ── ADDRESS ── */
  .wa-addr-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .wa-addr-grid .wa-field-group.full { grid-column: 1 / -1; }
  .wa-address-card {
    border: 1.5px solid #e2e8f0; border-radius: 12px;
    padding: 16px; cursor: pointer;
    transition: all 0.2s; margin-bottom: 10px;
    position: relative;
  }
  .wa-address-card:hover { border-color: #94a3b8; }
  .wa-address-card.selected { border-color: #0f172a; background: #f8fafc; }
  .wa-address-card.selected::after {
    content: '✓';
    position: absolute; top: 12px; right: 14px;
    width: 22px; height: 22px; border-radius: 50%;
    background: #0f172a; color: #fff;
    font-size: 12px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
  }
  .wa-addr-name { font-size: 14px; font-weight: 700; color: #0f172a; margin-bottom: 4px; }
  .wa-addr-text { font-size: 13px; color: #64748b; line-height: 1.5; }

  /* ── ORDER SUMMARY ── */
  .wa-order-summary {
    background: #f8fafc; border: 1px solid #e2e8f0;
    border-radius: 14px; padding: 20px; margin: 20px 0;
  }
  .wa-summary-title { font-size: 13px; font-weight: 700; color: #374151; margin-bottom: 14px; text-transform: uppercase; letter-spacing: 0.5px; }
  .wa-summary-row {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 14px; color: #64748b; padding: 7px 0;
  }
  .wa-summary-row:not(:last-child) { border-bottom: 1px solid #f1f5f9; }
  .wa-summary-row.total {
    font-size: 16px; font-weight: 800; color: #0f172a;
    padding-top: 14px; margin-top: 4px;
    border-top: 2px solid #e2e8f0 !important;
  }
  .wa-free-label { color: #16a34a; font-weight: 600; }

  /* ── COUPON ── */
  .wa-coupon-row { display: flex; gap: 10px; margin-bottom: 16px; }
  .wa-coupon-row .wa-input { flex: 1; font-size: 14px; text-transform: uppercase; }
  .wa-coupon-apply {
    padding: 0 20px; background: #f1f5f9;
    border: 1.5px solid #e2e8f0; border-radius: 10px;
    font-size: 14px; font-weight: 700; color: #374151;
    cursor: pointer; white-space: nowrap; transition: all 0.2s;
  }
  .wa-coupon-apply:hover { background: #e2e8f0; }

  /* ── PAYMENT PILLS ── */
  .wa-pay-divider { display: flex; align-items: center; gap: 12px; margin: 20px 0 16px; }
  .wa-pay-divider::before, .wa-pay-divider::after { content: ''; flex: 1; height: 1px; background: #e2e8f0; }
  .wa-pay-divider span { font-size: 12px; color: #94a3b8; font-weight: 500; white-space: nowrap; }
  .wa-pay-online-btn {
    width: 100%; padding: 13px;
    background: #fff; color: #374151;
    border: 1.5px solid #e2e8f0; border-radius: 10px;
    font-size: 14px; font-weight: 600; cursor: pointer;
    transition: all 0.2s; display: flex; align-items: center;
    justify-content: center; gap: 8px;
  }
  .wa-pay-online-btn:hover { border-color: #94a3b8; background: #f8fafc; }

  /* ── SUCCESS ── */
  .wa-success-screen {
    display: none; text-align: center; padding: 60px 20px;
    flex-direction: column; align-items: center;
  }
  .wa-success-checkmark {
    width: 80px; height: 80px; border-radius: 50%;
    background: linear-gradient(135deg, #16a34a, #22c55e);
    display: flex; align-items: center; justify-content: center;
    font-size: 36px; margin: 0 auto 24px;
    box-shadow: 0 8px 30px rgba(22, 163, 74, 0.3);
    animation: wa-pop 0.4s cubic-bezier(0.17, 0.89, 0.32, 1.28) forwards;
  }
  @keyframes wa-pop { from { transform: scale(0.5); opacity: 0; } to { transform: scale(1); opacity: 1; } }

  /* ── ERROR ── */
  .wa-error-msg {
    font-size: 13px; color: #dc2626; font-weight: 500;
    background: #fef2f2; border: 1px solid #fecaca;
    border-radius: 8px; padding: 10px 14px;
    margin-top: 12px; display: none;
  }

  /* ── RESEND LINK ── */
  .wa-resend { text-align: center; margin-top: 20px; }
  .wa-resend a { font-size: 13px; color: #3b82f6; text-decoration: none; font-weight: 500; }
  .wa-resend a:hover { text-decoration: underline; }

  /* ── WHATSAPP NOTE ── */
  .wa-wa-note {
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; color: #64748b; margin-top: 16px;
    padding: 10px 14px; background: #f0fdf4;
    border-radius: 8px; border: 1px solid #bbf7d0;
  }

  /* ── DESKTOP LAYOUT ── */
  @media (min-width: 768px) {
    .wa-left-panel { display: flex; }
    .wa-checkout-wrapper { min-height: 100vh; }
    .wa-content-area { padding: 48px 44px; }
    .wa-modal-header { padding: 24px 44px; }
    .wa-otp-boxes { gap: 16px; }
    .wa-otp-box { width: 72px; height: 72px; font-size: 28px; }
  }

  /* ── MOBILE ── */
  @media (max-width: 767px) {
    .wa-content-area { padding: 24px 20px; }
    .wa-modal-header { padding: 16px 20px; }
    .wa-section-title { font-size: 20px; }
    .wa-addr-grid { grid-template-columns: 1fr; }
    .wa-otp-box { width: 56px; height: 56px; font-size: 22px; }
    .wa-otp-boxes { gap: 10px; }
  }

  #wa-step-2, #wa-step-3, #wa-step-4, .wa-success-screen, #wa-new-address-form { display: none; }
  
  .wa-payment-option {
    border: 1.5px solid #e2e8f0;
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 12px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .wa-payment-option:hover { border-color: #94a3b8; }
  .wa-payment-option.selected {
    border-color: #0f172a;
    background: #f8fafc;
    box-shadow: 0 0 0 1px #0f172a;
  }
  .wa-payment-radio {
    width: 20px; height: 20px; border-radius: 50%;
    border: 2px solid #cbd5e1;
    display: flex; align-items: center; justify-content: center;
  }
  .wa-payment-option.selected .wa-payment-radio {
    border-color: #0f172a;
  }
  .wa-payment-option.selected .wa-payment-radio::after {
    content: ''; width: 10px; height: 10px; border-radius: 50%;
    background: #0f172a;
  }
{% endstyle %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://sdk.cashfree.com/js/v3/cashfree.js"></script>

<!-- Inject logged-in Shopify customer data for pre-fill -->
<script>
window._shopifyCustomer = {
  {% if customer %}
  logged_in: true,
  first_name: {{ customer.first_name | json }},
  last_name: {{ customer.last_name | json }},
  email: {{ customer.email | json }},
  phone: {{ customer.phone | default: '' | json }},
  addresses: [
    {% for addr in customer.addresses %}
    {
      id: {{ addr.id | json }},
      first_name: {{ addr.first_name | json }},
      last_name: {{ addr.last_name | json }},
      address1: {{ addr.address1 | json }},
      city: {{ addr.city | json }},
      zip: {{ addr.zip | json }},
      province: {{ addr.province | json }},
      country: {{ addr.country | json }},
      phone: {{ addr.phone | default: '' | json }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
  {% else %}
  logged_in: false,
  first_name: '',
  last_name: '',
  email: '',
  phone: '',
  addresses: []
  {% endif %}
};
</script>

<div id="wa-otp-overlay">
  <div class="wa-checkout-wrapper">
    
    <!-- LEFT PANEL (desktop) -->
    <div class="wa-left-panel">
      <div>
        <div class="wa-brand-name" style="text-transform: uppercase;">{{ shop.domain | remove: '.myshopify.com' }}</div>
        <div class="wa-brand-tagline">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          100% Secure Checkout
        </div>
        <div class="wa-trust-badges">
          <div class="wa-trust-item">
            <div class="wa-trust-icon">🔐</div>
            <div>
              <div style="font-weight:600;">OTP Verified</div>
              <div style="font-size:12px; color:rgba(255,255,255,0.5);">Your phone number is verified securely</div>
            </div>
          </div>
          <div class="wa-trust-item">
            <div class="wa-trust-icon">🚚</div>
            <div>
              <div style="font-weight:600;">Free Delivery</div>
              <div style="font-size:12px; color:rgba(255,255,255,0.5);">Pan-India delivery at no extra cost</div>
            </div>
          </div>
          <div class="wa-trust-item">
            <div class="wa-trust-icon">💳</div>
            <div>
              <div style="font-weight:600;">Pay COD or Online</div>
              <div style="font-size:12px; color:rgba(255,255,255,0.5);">Pay on delivery or UPI/Card</div>
            </div>
          </div>
          <div class="wa-trust-item">
            <div class="wa-trust-icon">↩️</div>
            <div>
              <div style="font-weight:600;">Easy Returns</div>
              <div style="font-size:12px; color:rgba(255,255,255,0.5);">Hassle-free 7 day return policy</div>
            </div>
          </div>
        </div>
      </div>
      <div class="wa-left-footer">&copy; {{ 'now' | date: "%Y" }} {{ shop.domain | remove: '.myshopify.com' }}. All rights reserved.</div>
    </div>

    <!-- RIGHT PANEL -->
    <div class="wa-right-panel">
      
      <!-- HEADER -->
      <div class="wa-modal-header">
        <div class="wa-mobile-brand">
          <div class="wa-mobile-logo-text" style="text-transform: uppercase;">{{ shop.domain | remove: '.myshopify.com' }}</div>
          <div class="wa-secure-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color:#16a34a"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Secure
          </div>
        </div>
        <button class="wa-close-btn" onclick="closeWaModal()">×</button>
      </div>

      <!-- CONTENT -->
      <div class="wa-content-area">
        
        <!-- Step Indicator -->
        <div class="wa-steps" id="wa-steps-indicator">
          <div class="wa-step-dot active" id="wa-dot-1">1</div>
          <div class="wa-step-line" id="wa-line-1"></div>
          <div class="wa-step-dot" id="wa-dot-2">2</div>
          <div class="wa-step-line" id="wa-line-2"></div>
          <div class="wa-step-dot" id="wa-dot-3">3</div>
          <div class="wa-step-line" id="wa-line-3"></div>
          <div class="wa-step-dot" id="wa-dot-4">4</div>
        </div>

        <!-- STEP 1: PHONE -->
        <div id="wa-step-1">
          <div class="wa-section-eyebrow">Step 1 of 3</div>
          <h2 class="wa-section-title" id="wa-title-1">Swift Checkout</h2>
          <p class="wa-section-desc" id="wa-desc-1">Enter your WhatsApp number to receive an OTP and complete your order.</p>
          
          <div class="wa-field-group" id="wa-phone-container">
            <label class="wa-field-label">Mobile Number</label>
            <div class="wa-phone-row">
              <div class="wa-phone-prefix">🇮🇳 +91</div>
              <input type="tel" id="wa-phone" class="wa-input" placeholder="98765 43210" maxlength="10" oninput="this.value=this.value.replace(/\D/g,'')">
            </div>
          </div>

          <div id="wa-switch-account" style="display:none; margin-bottom:16px;">
            <a href="#" onclick="waSwitchAccount(event)" style="font-size:13px; color:#3b82f6; text-decoration:none; font-weight:500;">Use a different number →</a>
          </div>

          <!-- Email field -->
          <div class="wa-field-group" style="margin-top:4px;">
            <label class="wa-field-label">Email Address <span style="font-weight:400;color:#94a3b8;font-size:12px;">(Optional)</span></label>
            <input type="email" id="wa-email" class="wa-input" placeholder="you@example.com (Optional)">
          </div>

          <div class="wa-wa-note">
            <span style="font-size:18px;">💬</span>
            <span>OTP will be sent on your <strong>WhatsApp</strong></span>
          </div>

          <div style="margin-top:20px;">
            <button type="button" class="wa-btn-primary" id="wa-send-btn" onclick="sendWaOtp()">
              Continue
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>

        <!-- STEP 2: OTP -->
        <div id="wa-step-2">
          <div class="wa-section-eyebrow">Step 2 of 3</div>
          <h2 class="wa-section-title">Verify OTP</h2>
          <p class="wa-section-desc" id="wa-otp-desc">Enter the 4-digit OTP sent to your WhatsApp.</p>
          
          <div class="wa-otp-boxes">
            <input type="tel" class="wa-otp-box" maxlength="1" oninput="waOtpInput(this,0)" onkeydown="waOtpKey(event,0)">
            <input type="tel" class="wa-otp-box" maxlength="1" oninput="waOtpInput(this,1)" onkeydown="waOtpKey(event,1)">
            <input type="tel" class="wa-otp-box" maxlength="1" oninput="waOtpInput(this,2)" onkeydown="waOtpKey(event,2)">
            <input type="tel" class="wa-otp-box" maxlength="1" oninput="waOtpInput(this,3)" onkeydown="waOtpKey(event,3)">
          </div>
          
          <div class="wa-error-msg" id="wa-otp-error"></div>

          <div style="margin-top:24px;">
            <button type="button" class="wa-btn-primary" id="wa-verify-btn" onclick="verifyWaOtp()">
              Verify & Continue
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </div>

          <div class="wa-resend" id="wa-resend-container">
            <a href="#" id="wa-resend-link" onclick="sendWaOtp(); return false;">Didn't receive? Resend OTP</a>
            <span id="wa-resend-timer" style="display:none; color:#64748b; font-size:13px;"></span>
          </div>
        </div>

        <!-- STEP 3: ADDRESS & PAYMENT -->
        <div id="wa-step-3">
          <div class="wa-section-eyebrow">Step 3 of 3</div>
          <h2 class="wa-section-title">Delivery & Payment</h2>
          <p class="wa-section-desc">Choose a delivery address and place your order.</p>

          <!-- Address List -->
          <div id="wa-address-list"></div>
          
          <button type="button" onclick="waShowNewAddressForm()" id="wa-add-addr-btn" style="width:100%;padding:13px;border:1.5px dashed #cbd5e1;background:transparent;border-radius:10px;font-size:14px;font-weight:600;color:#64748b;cursor:pointer;margin-bottom:20px;transition:0.2s;">
            + Add New Address
          </button>

          <!-- New Address Form -->
          <div id="wa-new-address-form">
            <div style="font-size:15px; font-weight:700; color:#0f172a; margin-bottom:4px;">New Address</div>
            <div style="font-size:12px; color:#64748b; margin-bottom:12px;">Enter PIN code to auto-fill location details</div>
            <div class="wa-addr-grid">
              <div class="wa-field-group">
                <label class="wa-field-label">First Name</label>
                <input type="text" id="wa-addr-fname" class="wa-input" placeholder="Rahul">
              </div>
              <div class="wa-field-group">
                <label class="wa-field-label">Last Name</label>
                <input type="text" id="wa-addr-lname" class="wa-input" placeholder="Sharma">
              </div>
              <div class="wa-field-group full">
                <label class="wa-field-label">Street Address</label>
                <input type="text" id="wa-addr-street" class="wa-input" placeholder="House No, Street, Locality">
              </div>

              <!-- PIN CODE with auto-fill -->
              <div class="wa-field-group">
                <label class="wa-field-label">PIN Code</label>
                <div style="position:relative;">
                  <input type="tel" id="wa-addr-zip" class="wa-input" placeholder="400001" maxlength="6"
                    oninput="this.value=this.value.replace(/\D/g,''); if(this.value.length===6) waLookupPincode(this.value)">
                  <span id="wa-pin-spinner" style="display:none;position:absolute;right:12px;top:50%;transform:translateY(-50%);font-size:12px;color:#64748b;">⟳ Loading...</span>
                </div>
              </div>
              <div class="wa-field-group" id="wa-pin-status-wrap" style="display:flex;align-items:flex-end;">
                <span id="wa-pin-status" style="font-size:12px;"></span>
              </div>

              <!-- City (auto-filled) -->
              <div class="wa-field-group">
                <label class="wa-field-label">City / Post Office</label>
                <div id="wa-city-select-wrapper" style="display:none;">
                  <select id="wa-addr-city-select" class="wa-input" style="cursor:pointer;" onchange="document.getElementById('wa-addr-city-input').value = this.value;"></select>
                </div>
                <input type="text" id="wa-addr-city-input" class="wa-input" placeholder="City">
              </div>

              <!-- District (auto-filled) -->
              <div class="wa-field-group" id="wa-district-field">
                <label class="wa-field-label">District</label>
                <input type="text" id="wa-addr-district" class="wa-input" placeholder="District" readonly style="background:#f8fafc; cursor:not-allowed;">
              </div>

              <!-- State (auto-filled) -->
              <div class="wa-field-group full" id="wa-state-field">
                <label class="wa-field-label">State</label>
                <input type="text" id="wa-addr-state" class="wa-input" placeholder="State" readonly style="background:#f8fafc; cursor:not-allowed;">
              </div>
            </div>

            <div id="wa-pin-error" style="display:none;font-size:12px;color:#dc2626;margin:-8px 0 12px;padding:8px 12px;background:#fef2f2;border-radius:8px;border:1px solid #fecaca;"></div>

            <button type="button" id="wa-save-addr-btn" class="wa-btn-primary" onclick="waSaveNewAddress()" style="margin-bottom:20px;">
              Save Address
            </button>
          </div>

          <!-- Coupon -->
          <div class="wa-coupon-row">
            <input type="text" id="wa-coupon-code" class="wa-input" placeholder="DISCOUNT CODE" style="text-transform:uppercase;">
            <button type="button" class="wa-coupon-apply" onclick="waApplyCoupon()">Apply</button>
          </div>

          <!-- Order Summary -->
          <div class="wa-order-summary">
            <div class="wa-summary-title">Order Summary</div>
            <div class="wa-summary-row">
              <span>Subtotal</span>
              <span id="wa-subtotal" style="font-weight:600; color:#0f172a;">Calculating...</span>
            </div>
            <div class="wa-summary-row">
              <span>Shipping</span>
              <span class="wa-free-label">FREE</span>
            </div>
            <div class="wa-summary-row total">
              <span>Total</span>
              <span id="wa-total">---</span>
            </div>
          </div>

          <div style="margin-top:20px;">
            <button type="button" class="wa-btn-primary" id="wa-proceed-payment-btn" onclick="waProceedToPayment()">
              Proceed to Payment
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>

        <!-- STEP 4: PAYMENT -->
        <div id="wa-step-4">
          <div class="wa-section-eyebrow">Step 4 of 4</div>
          <h2 class="wa-section-title">Payment Method</h2>
          <p class="wa-section-desc">Choose how you'd like to pay for your order.</p>

          <div id="wa-payment-error" style="color: #ef4444; font-size: 13px; font-weight: 500; margin-bottom: 12px; display: none;"></div>
          <div id="wa-payment-methods-container">
            <!-- Rendered dynamically -->
          </div>
          
          <div style="margin-top:24px;">
            <button type="button" class="wa-btn-primary" id="wa-cod-btn" onclick="waPayNow()">
              <span id="wa-pay-btn-text">Pay Now</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </div>
          <div style="margin-top:12px; text-align:center;">
            <button type="button" class="wa-btn-secondary" onclick="waBackToAddress()">
              Back to Address
            </button>
          </div>
        </div>

        <!-- SUCCESS SCREEN -->
        <div class="wa-success-screen" id="wa-success-screen">
          <div class="wa-success-checkmark">✓</div>
          <h2 class="wa-section-title">Order Placed!</h2>
          <p class="wa-section-desc" style="max-width:320px; margin:0 auto 32px;">Your COD order has been successfully placed. You will receive a confirmation on WhatsApp shortly.</p>
          <button type="button" class="wa-btn-primary" style="max-width:280px;" onclick="window.location='/'">Continue Shopping</button>
        </div>

      </div>
    </div>
  </div>
</div>

<script>
  const WA_API_BASE = 'https://checkout-app-one-lilac.vercel.app/api';
  const MERCHANT_KEY = 'sk_live_11fit_106b31bb8dd7a7';

  let waPhone = null;
  let waSignature = null;
  let waOtpSendCount = 0;
  let waResendInterval = null;
  let waEditingAddressId = null;
  let waSelectedAddress = null;
  let waAddresses = [];
  let waDraftOrderId = null;
  let waInvoiceUrl = null;
  let waEmail = '';
  let waAppliedDiscountCode = null;
  let waShopifyAddressesLoaded = false;
  let waMapSearchTimer = null;
  let waPaymentSettings = {};

  document.addEventListener('DOMContentLoaded', () => {
    if (!localStorage.getItem('fit11_device_id')) {
      localStorage.setItem('fit11_device_id', 'dev_' + Math.random().toString(36).substr(2, 9));
    }
  });

  // ── MAP / LOCATION SEARCH (OpenStreetMap Nominatim - FREE, no API key) ──
  function waSearchAddress(query) {
    clearTimeout(waMapSearchTimer);
    const sugBox = document.getElementById('wa-map-suggestions');
    if (!query || query.length < 3) { sugBox.style.display = 'none'; return; }
    waMapSearchTimer = setTimeout(async () => {
      try {
        const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&countrycodes=in&addressdetails=1&limit=6&q=${encodeURIComponent(query)}`, {
          headers: { 'Accept-Language': 'en' }
        });
        const results = await res.json();
        sugBox.innerHTML = '';
        if (!results.length) {
          sugBox.innerHTML = '<div style="padding:12px;font-size:13px;color:#94a3b8;">No results found</div>';
        } else {
          results.forEach(r => {
            const div = document.createElement('div');
            div.style.cssText = 'padding:10px 14px;cursor:pointer;font-size:13px;border-bottom:1px solid #f1f5f9;color:#374151;';
            div.innerText = r.display_name;
            div.onmouseenter = () => div.style.background = '#f8fafc';
            div.onmouseleave = () => div.style.background = '';
            div.onclick = () => waFillFromNominatim(r);
            sugBox.appendChild(div);
          });
        }
        sugBox.style.display = 'block';
      } catch(e) { sugBox.style.display = 'none'; }
    }, 400);
  }

  function waFillFromNominatim(r) {
    const a = r.address || {};
    // Fill fields
    const city = a.city || a.town || a.village || a.suburb || a.neighbourhood || '';
    const district = a.county || a.state_district || '';
    const state = a.state || '';
    const postcode = a.postcode || '';
    const road = [a.house_number, a.road, a.suburb].filter(Boolean).join(', ');

    if (road) document.getElementById('wa-addr-street').value = road;
    if (city) document.getElementById('wa-addr-city').value = city;
    if (district) document.getElementById('wa-addr-district').value = district;
    if (postcode) document.getElementById('wa-addr-zip').value = postcode;

    // Set state dropdown
    if (state) {
      const sel = document.getElementById('wa-addr-state');
      for (let opt of sel.options) {
        if (opt.value.toLowerCase().includes(state.toLowerCase()) || state.toLowerCase().includes(opt.value.toLowerCase())) {
          opt.selected = true; break;
        }
      }
    }

    // Clear search
    document.getElementById('wa-map-search').value = city || state || '';
    document.getElementById('wa-map-suggestions').style.display = 'none';
  }

  function waUseMyLocation() {
    if (!navigator.geolocation) return alert('Geolocation not supported on this device.');
    const btn = event.target;
    btn.innerHTML = '⏳';
    navigator.geolocation.getCurrentPosition(async (pos) => {
      try {
        const { latitude, longitude } = pos.coords;
        const res = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${latitude}&lon=${longitude}&addressdetails=1`, {
          headers: { 'Accept-Language': 'en' }
        });
        const r = await res.json();
        waFillFromNominatim(r);
        document.getElementById('wa-map-search').value = '📍 Location detected';
      } catch(e) {
        alert('Could not detect location. Please search manually.');
      } finally { btn.innerHTML = '📍'; }
    }, () => { alert('Location access denied. Please search manually.'); btn.innerHTML = '📍'; });
  }

  // Close suggestions when clicking outside
  document.addEventListener('click', (e) => {
    if (!e.target.closest || !e.target.closest('#wa-new-address-form')) {
      const sugBox = document.getElementById('wa-map-suggestions');
      if (sugBox) sugBox.style.display = 'none';
    }
  });

  async function openWaModal() {
    const overlay = document.getElementById('wa-otp-overlay');
    if (!overlay) return;
    if (overlay.parentNode !== document.body) {
      document.body.appendChild(overlay);
    }
    overlay.style.cssText = 'position:fixed!important;top:0!important;left:0!important;width:100vw!important;height:100vh!important;z-index:2147483647!important;display:flex!important;align-items:flex-start!important;justify-content:center!important;overflow-y:auto!important;padding:0!important;background:rgba(15,23,42,0.6)!important;backdrop-filter:blur(6px)!important;-webkit-backdrop-filter:blur(6px)!important;';
    document.body.style.overflow = 'hidden';
    waResetModal();

    // Pre-fill from Shopify logged-in customer data
    const sc = window._shopifyCustomer;
    if (sc && sc.logged_in) {
      // Pre-fill phone if available
      if (sc.phone) {
        const cleanPhone = sc.phone.replace(/\D/g, '').replace(/^91/, '');
        document.getElementById('wa-phone').value = cleanPhone;
      }
      // Pre-fill email
      if (sc.email) {
        document.getElementById('wa-email').value = sc.email;
      }
      // Pre-load Shopify addresses (merge with network_addresses later)
      if (sc.addresses && sc.addresses.length > 0) {
        waAddresses = sc.addresses.map(a => ({
          id: 'shopify_' + a.id,
          first_name: a.first_name || '',
          last_name: a.last_name || '',
          address1: a.address1 || '',
          city: a.city || '',
          zip: a.zip || '',
          province: a.province || '',
          country: a.country || 'India'
        }));
        waShopifyAddressesLoaded = true;
      }
    }

    // Check if they already verified in this tab session
    const cachedPhone = sessionStorage.getItem('fit11_verified_phone');
    if (cachedPhone) {
      waPhone = cachedPhone;
      document.getElementById('wa-step-1').style.display = 'none';
      document.getElementById('wa-step-2').style.display = 'none';
      document.getElementById('wa-step-3').style.display = 'block';
      const cachedEmail = sessionStorage.getItem('fit11_verified_email');
      if (cachedEmail) document.getElementById('wa-email').value = cachedEmail;
      waSetStep(3);
      loadAddresses();
      calculateCheckoutTotals();
      return; // Skip identify check completely!
    }

    // Check identity via device (for "Welcome Back" flow if no session cache)
    try {
      const device_id = localStorage.getItem('fit11_device_id');
      const res = await fetch(`${WA_API_BASE}/identify`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ device_id, merchant_key: MERCHANT_KEY })
      });
      const data = await res.json();
      if (data.identified && data.masked_phone) {
        document.getElementById('wa-title-1').innerText = 'Welcome Back!';
        document.getElementById('wa-desc-1').innerText = `Continue as ${data.masked_phone}?`;
        document.getElementById('wa-phone-container').style.display = 'none';
        document.getElementById('wa-switch-account').style.display = 'block';
        waPhone = 'MASKED';
        if (data.email) {
          document.getElementById('wa-email').value = data.email;
        }
      }
    } catch (e) { /* Silent fail */ }
  }

  function waResetModal() {
    document.getElementById('wa-step-1').style.display = 'block';
    document.getElementById('wa-step-2').style.display = 'none';
    document.getElementById('wa-step-3').style.display = 'none';
    document.getElementById('wa-success-screen').style.display = 'none';
    document.getElementById('wa-steps-indicator').style.display = 'flex';
    waSetStep(1);
  }

  function waSetStep(step) {
    [1,2,3].forEach(i => {
      const dot = document.getElementById('wa-dot-' + i);
      if (dot) {
        dot.className = 'wa-step-dot' + (i < step ? ' done' : i === step ? ' active' : '');
        dot.textContent = i < step ? '✓' : i;
      }
    });
    [1,2].forEach(i => {
      const line = document.getElementById('wa-line-' + i);
      if (line) line.className = 'wa-step-line' + (i < step ? ' done' : '');
    });
  }

  function closeWaModal() {
    const overlay = document.getElementById('wa-otp-overlay');
    overlay.style.display = 'none';
    document.body.style.overflow = '';
  }

  function waSwitchAccount(e) {
    if (e) e.preventDefault();
    document.getElementById('wa-title-1').innerText = 'Swift Checkout';
    document.getElementById('wa-desc-1').innerText = 'Enter your WhatsApp number to receive an OTP and complete your order.';
    document.getElementById('wa-phone-container').style.display = 'block';
    document.getElementById('wa-switch-account').style.display = 'none';
    waPhone = null;
    document.getElementById('wa-phone').value = '';
  }

  // OTP box navigation
  function waOtpInput(el, idx) {
    el.value = el.value.replace(/\D/g, '');
    if (el.value.length === 1) {
      const boxes = document.querySelectorAll('.wa-otp-box');
      if (idx < 3) boxes[idx + 1].focus();
    }
    if (waGetOtp().length === 4) {
      verifyWaOtp();
    }
  }
  function waOtpKey(e, idx) {
    if (e.key === 'Backspace') {
      const boxes = document.querySelectorAll('.wa-otp-box');
      if (!boxes[idx].value && idx > 0) boxes[idx - 1].focus();
    }
  }
  function waGetOtp() {
    return [...document.querySelectorAll('.wa-otp-box')].map(b => b.value).join('');
  }

  async function sendWaOtp() {
    let phoneInput = document.getElementById('wa-phone').value.trim();
    if (waPhone !== 'MASKED') {
      if (phoneInput.length < 10) return alert('Please enter a valid 10-digit mobile number');
      waPhone = phoneInput;
    }
    waEmail = document.getElementById('wa-email').value.trim();
    const btn = document.getElementById('wa-send-btn');
    btn.disabled = true; btn.innerHTML = 'Sending OTP...';
    try {
      const payload = { merchant_key: MERCHANT_KEY };
      if (waPhone === 'MASKED') payload.device_id = localStorage.getItem('fit11_device_id');
      else payload.phone = waPhone;
      const res = await fetch(`${WA_API_BASE}/send-otp`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error);
      
      waOtpSendCount++;
      startResendTimer();
      
      waSignature = data.signature;
      if (data.real_phone) waPhone = data.real_phone;
      document.getElementById('wa-otp-desc').innerText = `Enter the OTP sent to +91 ${waPhone}`;
      document.getElementById('wa-step-1').style.display = 'none';
      document.getElementById('wa-step-2').style.display = 'block';
      waSetStep(2);
      setTimeout(() => document.querySelectorAll('.wa-otp-box')[0].focus(), 100);
    } catch (err) {
      const errMsg = err.message || 'Failed to send OTP. Please try again.';
      console.error('OTP Error:', errMsg);
      alert(errMsg);
    } finally {
      btn.disabled = false;
      btn.innerHTML = 'Continue <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';
    }
  }

  function startResendTimer() {
    clearInterval(waResendInterval);
    let timeLeft = waOtpSendCount === 1 ? 60 : 300;
    const link = document.getElementById('wa-resend-link');
    const timerText = document.getElementById('wa-resend-timer');
    
    link.style.display = 'none';
    timerText.style.display = 'inline-block';
    
    waResendInterval = setInterval(() => {
      timeLeft--;
      if (timeLeft <= 0) {
        clearInterval(waResendInterval);
        link.style.display = 'inline-block';
        timerText.style.display = 'none';
      } else {
        const m = Math.floor(timeLeft / 60);
        const s = timeLeft % 60;
        timerText.innerText = `Resend OTP in ${m}:${s.toString().padStart(2, '0')}`;
      }
    }, 1000);
  }

  async function verifyWaOtp() {
    const btn = document.getElementById('wa-verify-btn');
    if (btn.disabled) return; // Prevent double-submit
    const otp = waGetOtp();
    if (otp.length < 4) return;
    const errEl = document.getElementById('wa-otp-error');
    btn.disabled = true;
    btn.innerHTML = 'Verifying...';
    errEl.style.display = 'none';
    try {
      const res = await fetch(`${WA_API_BASE}/verify-otp`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ merchant_key: MERCHANT_KEY, phone: waPhone, otp, signature: waSignature, device_id: localStorage.getItem('fit11_device_id') })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Invalid OTP');
      
      // Save to session so they don't have to re-verify if they navigate away and come back
      sessionStorage.setItem('fit11_verified_phone', waPhone);
      if (data.profile && data.profile.email) {
        sessionStorage.setItem('fit11_verified_email', data.profile.email);
        document.getElementById('wa-email').value = data.profile.email;
      }
      
      document.getElementById('wa-step-2').style.display = 'none';
      document.getElementById('wa-step-3').style.display = 'block';
      waSetStep(3);
      await loadAddresses();
      await calculateCheckoutTotals();
    } catch (err) {
      errEl.innerText = err.message || 'Invalid OTP. Please try again.';
      errEl.style.display = 'block';
      document.querySelectorAll('.wa-otp-box').forEach(b => b.value = '');
      document.querySelectorAll('.wa-otp-box')[0].focus();
    } finally {
      btn.disabled = false;
      btn.innerHTML = 'Verify & Continue <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';
    }
  }

  async function loadAddresses() {
    try {
      const res = await fetch(`${WA_API_BASE}/addresses`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ merchant_key: MERCHANT_KEY, phone: waPhone, action: 'FETCH' })
      });
      const data = await res.json();
      const networkAddrs = data.addresses || [];
      
      // Merge: start with Shopify addresses (already pre-loaded), then add network ones
      const existingIds = new Set(waAddresses.map(a => a.address1 + a.zip));
      networkAddrs.forEach(a => {
        const key = (a.address1 || '') + (a.zip || '');
        if (!existingIds.has(key)) waAddresses.push(a);
      });
      
      renderAddresses();
    } catch (e) { renderAddresses(); }
  }

  function renderAddresses() {
    const list = document.getElementById('wa-address-list');
    list.innerHTML = '';
    if (waAddresses.length === 0) {
      waShowAddressForm();
      document.getElementById('wa-cod-btn').disabled = true;
      return;
    }
    document.getElementById('wa-add-addr-btn').style.display = 'block';
    document.getElementById('wa-new-address-form').style.display = 'none';

    if (!waSelectedAddress) waSelectedAddress = waAddresses[0].id;

    // Find the selected address, fallback to first if not found
    let primary = waAddresses.find(a => a.id == waSelectedAddress) || waAddresses[0];
    const otherAddresses = waAddresses.filter(a => a.id != primary.id);

    let html = `
        <div class="wa-address-card selected" style="padding:16px;">
          <div style="display:flex; justify-content:space-between; align-items:flex-start;">
            <div style="cursor:pointer; flex:1;" onclick="waSelectAddress('${primary.id}')">
              <div class="wa-addr-name">${primary.first_name} ${primary.last_name}</div>
              <div class="wa-addr-text">${primary.address1}<br/>${primary.city} - ${primary.zip}</div>
              ${primary.company ? `<div class="wa-addr-text" style="color:#94a3b8;">${primary.company}</div>` : ''}
              
              <div style="display:flex;gap:12px;margin-top:10px;">
                ${!primary.id.toString().startsWith('shopify_') ? `<button onclick="waEditAddress('${primary.id}')" style="background:none;border:none;color:#3b82f6;font-size:13px;font-weight:600;cursor:pointer;padding:0;text-decoration:none;">Edit</button>` : ''}
                <button onclick="waDeleteAddress('${primary.id}')" style="background:none;border:none;color:#ef4444;font-size:13px;font-weight:600;cursor:pointer;padding:0;text-decoration:none;">Delete</button>
              </div>
            </div>
          </div>
        </div>
    `;

    // Render the rest in an accordion if there are more
    if (otherAddresses.length > 0) {
      html += `
