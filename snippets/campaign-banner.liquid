{% assign campaign = product.metafields.custom.active_campaign.value %}
{% if campaign %}
  <div class="fit11-offer-card" style="margin: 16px 0; width: 100%; min-width: 100%; border-color: #ffdf00; cursor: default; flex-direction: column; padding: 16px;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
      <div class="fit11-offer-code" style="font-size: 14px; font-weight: 600; color: #1a202c; text-transform: uppercase;">
        {{ campaign.campaignName | escape }}
      </div>
      <div style="background: #198754; color: #fff; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 700; text-transform: uppercase;">Auto Applied</div>
    </div>
    
    <div class="fit11-offer-desc" style="font-size: 13px; color: #1a202c; font-weight: 500; margin-top: 4px;">
      {% if campaign.discountType == 'FLAT_RATE' %}
        Buy {{ campaign.minQuantity }} items for a
      {% elsif campaign.minQuantity > 1 %}
        Buy {{ campaign.minQuantity }} or more items and get
      {% else %}
        Get
      {% endif %}
      <span style="color: #198754; font-weight: 700;">
        {% if campaign.discountType == 'PERCENTAGE' %}
          {{ campaign.discountValue }}% OFF
        {% elsif campaign.discountType == 'FLAT_RATE' %}
          FLAT ₹{{ campaign.discountValue }}
        {% else %}
          ₹{{ campaign.discountValue }} OFF Each Item
        {% endif %}
      </span>
    </div>
    
    <div class="fit11-offer-desc" style="font-weight: 600; color: #d9480f; margin-top: 6px; font-size: 13px;">
      <i class="ti ti-flame"></i> Limited Time Deal!
    </div>
    
    <div style="border-top: 1px dashed #cbd5e0; margin-top: 12px; padding-top: 10px; display: flex; justify-content: space-between; font-size: 11px; font-weight: 500; color: #718096;">
      <span style="color: #198754; display: flex; align-items: center; gap: 4px;"><i class="ti ti-truck"></i> Free Delivery Eligible</span>
      <span>No Coupon Needed</span>
    </div>
  </div>
{% endif %}
