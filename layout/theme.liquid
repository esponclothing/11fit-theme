<style>
  /* Global Scroll Animations */
  .pc-reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .pc-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  /* Stagger children if needed */
  .pc-reveal-stagger > * {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .pc-reveal-stagger.is-visible > * {
    opacity: 1;
    transform: translateY(0);
  }
  .pc-reveal-stagger.is-visible > *:nth-child(1) { transition-delay: 0.1s; }
  .pc-reveal-stagger.is-visible > *:nth-child(2) { transition-delay: 0.2s; }
  .pc-reveal-stagger.is-visible > *:nth-child(3) { transition-delay: 0.3s; }
  .pc-reveal-stagger.is-visible > *:nth-child(4) { transition-delay: 0.4s; }
  .pc-reveal-stagger.is-visible > *:nth-child(5) { transition-delay: 0.5s; }
  .pc-reveal-stagger.is-visible > *:nth-child(6) { transition-delay: 0.6s; }
  .pc-reveal-stagger.is-visible > *:nth-child(7) { transition-delay: 0.7s; }
  .pc-reveal-stagger.is-visible > *:nth-child(8) { transition-delay: 0.8s; }
</style>
<script>
  function removeFit11Preloader() {
    var p = document.getElementById('fit11-preloader');
    if (p && p.style.visibility !== 'hidden') {
      p.style.opacity = '0';
      p.style.visibility = 'hidden';
      document.documentElement.classList.add('page-loaded');
    }
    sessionStorage.setItem('fit11_loaded', 'true');
  }
  
  function addVariantToCart(variantId, button) {
    if (!variantId) return;
    if (button) {
      button.classList.add('loading');
      button.disabled = true;
    }

    const cart = document.querySelector('cart-notification') || document.querySelector('cart-drawer');
    const sections = cart ? cart.getSectionsToRender().map((s) => s.id) : [];

    const body = JSON.stringify({
      id: variantId,
      quantity: 1,
      sections: sections,
      sections_url: window.location.pathname
    });

    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: body
    })
    .then(response => response.json())
    .then(parsedState => {
      if (parsedState.status) {
        alert(parsedState.description || parsedState.message);
        return;
      }
      if (cart) {
        if (cart.classList.contains('is-empty')) cart.classList.remove('is-empty');
        cart.renderContents(parsedState);
      } else {
        window.location = '/cart';
      }
    })
    .catch(error => {
      console.error('Error adding variant to cart:', error);
    })
    .finally(() => {
      if (button) {
        button.classList.remove('loading');
        button.disabled = false;
      }
    });
  }

  document.addEventListener('DOMContentLoaded', function() { 
    setTimeout(removeFit11Preloader, 600); 

    // Initialize Global Scroll Observer
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible', 'scroll-trigger--animate');
          observer.unobserve(entry.target); // Only animate once
        }
      });
    }, { rootMargin: "0px 0px -50px 0px", threshold: 0.1 });

    document.querySelectorAll('.pc-reveal, .pc-reveal-stagger, .scroll-trigger').forEach(el => observer.observe(el));

    // Autoplay Product Card Sliders (Optimized to prevent layout thrashing)
    setInterval(() => {
      const sliders = Array.from(document.querySelectorAll('.fit-card-slider'));
      const scrollOps = [];
      // Phase 1: Read all DOM properties to avoid layout thrashing
      sliders.forEach(slider => {
        if (!slider.isHovered && slider.scrollWidth > slider.clientWidth) {
          scrollOps.push({
            el: slider,
            width: slider.clientWidth,
            reset: slider.scrollLeft + slider.clientWidth >= slider.scrollWidth - 10
          });
        }
      });
      // Phase 2: Perform all DOM writes
      scrollOps.forEach(op => {
        if (op.reset) {
          op.el.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          op.el.scrollBy({ left: op.width, behavior: 'smooth' });
        }
      });
    }, 3000);

    document.querySelectorAll('.fit-card-slider').forEach(slider => {
      slider.addEventListener('mouseenter', () => slider.isHovered = true);
      slider.addEventListener('mouseleave', () => slider.isHovered = false);
      slider.addEventListener('touchstart', () => slider.isHovered = true, {passive: true});
      slider.addEventListener('touchend', () => { setTimeout(() => slider.isHovered = false, 3000); }, {passive: true});
    });

    // Color Swatch Clicks
    document.querySelectorAll('.fit-color-dot').forEach(dot => {
      dot.addEventListener('click', (e) => {
        e.preventDefault();
        const slideIndex = parseInt(dot.getAttribute('data-slide-index') || '0', 10);
        const cardMedia = dot.closest('.card__media');
        const slider = cardMedia ? cardMedia.querySelector('.fit-card-slider') : null;
        if (slider) {
          slider.scrollTo({ left: slideIndex * slider.clientWidth, behavior: 'smooth' });
          // Temporarily pause autoplay
          slider.isHovered = true;
          setTimeout(() => slider.isHovered = false, 5000);
        }
      });
    });
  });
  setTimeout(removeFit11Preloader, 2000);
  window.addEventListener('load', function() { setTimeout(removeFit11Preloader, 400); });
</script>
<!-- GLOBAL VARIANT PICKER MODAL (Quick Add) -->
<div id="lx-variant-modal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:999999; align-items:flex-end; justify-content:center;" onclick="if(event.target===this)lxCloseVariantModal()">
  <div style="background:#fff; border-radius:16px 16px 0 0; padding:24px 20px; width:100%; max-width:480px; max-height:80vh; overflow-y:auto; position:relative; font-family:'Outfit', sans-serif; box-sizing:border-box;">
    <button type="button" onclick="lxCloseVariantModal()" style="position:absolute;top:14px;right:16px;background:none;border:none;font-size:22px;cursor:pointer;color:#6B7280;">✕</button>
    <div id="lx-vm-img-wrap" style="display:flex;gap:14px;align-items:center;margin-bottom:18px;">
      <img id="lx-vm-img" src="" style="width:70px;height:88px;object-fit:cover;border-radius:8px;border:1px solid #eee;" alt="">
      <div>
        <p id="lx-vm-title" style="font-weight:700;font-size:14px;margin:0 0 4px;color:#1A202C;line-height:1.35;"></p>
        <p id="lx-vm-price" style="font-weight:600;font-size:13px;color:#B89356;margin:0;"></p>
      </div>
    </div>
    <div id="lx-vm-options"></div>
    <button type="button" id="lx-vm-add-btn" onclick="lxAddSelectedVariant()" style="width:100%;background:#1A202C;color:#fff;border:none;border-radius:10px;padding:14px;font-size:15px;font-weight:600;cursor:pointer;margin-top:16px;font-family:inherit;">Add to Cart</button>
  </div>
</div>

<script>
(function() {
  var _vmProduct = null;
  var _vmSelectedOptions = {};
  var _vmLineIndex = null;
  var _vmQty = null;

  window.lxOpenVariantModal = function(productId) {
    var p = window._lxProducts && window._lxProducts[productId];
    if (!p) return;
    _vmProduct = p;
    _vmSelectedOptions = {};
    _vmLineIndex = null;
    _vmQty = null;

    document.getElementById('lx-vm-img').src = p.featured_image || '';
    document.getElementById('lx-vm-title').textContent = p.title;
    document.getElementById('lx-vm-price').textContent = (p.price / 100).toLocaleString('en-IN', { style: 'currency', currency: 'INR', minimumFractionDigits: 0 });

    var addBtn = document.getElementById('lx-vm-add-btn');
    addBtn.textContent = 'Add to Cart';
    addBtn.style.background = '#1A202C';
    addBtn.disabled = false;

    lxRenderOptions(p);
    document.getElementById('lx-variant-modal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  };

  window.lxOpenChangeVariant = function(productId, lineIndex, qty) {
    fetch(window.Shopify.routes.root + 'products/' + productId + '.js')
      .then(function(r){ return r.json(); })
      .then(function(p) {
        _vmProduct = p;
        _vmSelectedOptions = {};
        _vmLineIndex = lineIndex;
        _vmQty = qty;

        document.getElementById('lx-vm-img').src = p.featured_image ? p.featured_image : '';
        document.getElementById('lx-vm-title').textContent = p.title;
        document.getElementById('lx-vm-price').textContent = (p.price / 100).toLocaleString('en-IN', { style: 'currency', currency: 'INR', minimumFractionDigits: 0 });

        var addBtn = document.getElementById('lx-vm-add-btn');
        addBtn.textContent = 'Update Variant';
        addBtn.style.background = '#B89356';
        addBtn.disabled = false;

        lxRenderOptions(p);
        document.getElementById('lx-variant-modal').style.display = 'flex';
        document.body.style.overflow = 'hidden';
      });
  };

  function lxRenderOptions(p) {
    var optHtml = '';
    p.options.forEach(function(opt, oi) {
      var vals = p.variants.map(function(v) { return v.options[oi]; }).filter(function(v,i,a){ return a.indexOf(v)===i; });
      optHtml += '<div style="margin-bottom:14px;">';
      optHtml += '<p style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:#6B7280;margin:0 0 8px;">' + opt + '</p>';
      optHtml += '<div style="display:flex;flex-wrap:wrap;gap:6px;">';
      vals.forEach(function(val) {
        optHtml += '<button type="button" class="lx-vm-opt-btn" data-option-index="' + oi + '" data-value="' + val + '" onclick="lxSelectOpt(this,' + oi + ',\'' + val.replace(/'/g,"\\'") + '\')" style="border:1.5px solid #E5E7EB;border-radius:6px;padding:6px 12px;font-size:13px;font-weight:500;background:#fff;cursor:pointer;transition:all 0.2s;">' + val + '</button>';
      });
      optHtml += '</div></div>';
    });
    document.getElementById('lx-vm-options').innerHTML = optHtml;
  }

  window.lxCloseVariantModal = function() {
    document.getElementById('lx-variant-modal').style.display = 'none';
    document.body.style.overflow = '';
    _vmProduct = null;
    _vmSelectedOptions = {};
    _vmLineIndex = null;
    _vmQty = null;
  };

  window.lxSelectOpt = function(btn, optIndex, val) {
    var btns = document.querySelectorAll('.lx-vm-opt-btn[data-option-index="' + optIndex + '"]');
    btns.forEach(function(b) { b.style.borderColor='#E5E7EB'; b.style.background='#fff'; b.style.color='#1A202C'; b.style.fontWeight='500'; });
    btn.style.borderColor = '#1A202C';
    btn.style.background = '#1A202C';
    btn.style.color = '#fff';
    btn.style.fontWeight = '700';
    _vmSelectedOptions[optIndex] = val;
  };

  window.lxAddSelectedVariant = function() {
    if (!_vmProduct) return;
    var numOpts = _vmProduct.options ? _vmProduct.options.length : 0;
    if (Object.keys(_vmSelectedOptions).length < numOpts) {
      var addBtn = document.getElementById('lx-vm-add-btn');
      var orig = addBtn.textContent;
      addBtn.textContent = 'Please select all options';
      addBtn.style.background = '#DC2626';
      setTimeout(function() { addBtn.textContent = orig; addBtn.style.background = _vmLineIndex ? '#B89356' : '#1A202C'; }, 1500);
      return;
    }
    var matched = _vmProduct.variants.find(function(v) {
      return v.options.every(function(o, i) { return _vmSelectedOptions[i] === o; });
    });
    if (!matched) return;
    var addBtn = document.getElementById('lx-vm-add-btn');
    addBtn.disabled = true;

    if (_vmLineIndex) {
      addBtn.textContent = 'Updating...';
      fetch(window.Shopify.routes.root + 'cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: _vmLineIndex, quantity: 0 })
      }).then(function() {
        return fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: matched.id, quantity: _vmQty || 1 })
        });
      }).then(function() {
        addBtn.textContent = '✓ Updated!';
        addBtn.style.background = '#16A34A';
        setTimeout(function() { lxCloseVariantModal(); location.reload(); }, 700);
      }).catch(function() {
        addBtn.textContent = 'Update Variant';
        addBtn.disabled = false;
      });
    } else {
      addBtn.textContent = 'Adding...';
      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: matched.id, quantity: 1 })
      }).then(function() {
        addBtn.textContent = '✓ Added!';
        addBtn.style.background = '#16A34A';
        setTimeout(function() { lxCloseVariantModal(); location.reload(); }, 700);
      }).catch(function() {
        addBtn.textContent = 'Add to Cart';
        addBtn.disabled = false;
      });
    }
  };

  window.lxDirectAdd = function(btn, variantId) {
    btn.textContent = 'Adding...';
    btn.disabled = true;
    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    }).then(function() {
      btn.textContent = '✓ Added!';
      btn.style.background = '#16A34A';
      setTimeout(function() { location.reload(); }, 800);
    }).catch(function() {
      btn.textContent = '+ Quick Add';
      btn.disabled = false;
    });
  };

  window.lxDirectChangeVariant = function(selectEl) {
    var picker = selectEl.closest('.lx-direct-picker');
    var lineIndex = parseInt(picker.getAttribute('data-line-index'), 10);
    var qty = parseInt(picker.getAttribute('data-qty'), 10);
    var selects = picker.querySelectorAll('.lx-direct-option-select');
    
    var selectedOptions = [];
    selects.forEach(function(sel) {
      var optIdx = parseInt(sel.getAttribute('data-option-index'), 10);
      selectedOptions[optIdx] = sel.value;
    });
    
    var jsonEl = picker.querySelector('.lx-direct-variants-json');
    if (!jsonEl) return;
    var variants = JSON.parse(jsonEl.textContent);
    
    var matched = variants.find(function(v) {
      return v.options.every(function(optVal, idx) {
        return selectedOptions[idx] === optVal;
      });
    });
    
    if (!matched) {
      alert('This combination is not available.');
      return;
    }
    
    selects.forEach(function(sel) { sel.disabled = true; });
    
    fetch(window.Shopify.routes.root + 'cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: lineIndex, quantity: 0 })
    }).then(function() {
      return fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: matched.id, quantity: qty })
      });
    }).then(function() {
      location.reload();
    }).catch(function() {
      selects.forEach(function(sel) { sel.disabled = false; });
    });
  };
  // --- GLOBAL VIP AUTO-APPLY & AUTO-REMOVE SYSTEM ---
  let isVerifyingVip = false;

  async function verifyVipState(isInitialLoad) {
    if (isVerifyingVip) return;
    
    const config = window.lxVipConfig || { vipCode: 'PURCHASE1999', vipThreshold: 250000 };
    const vipCode = config.vipCode;
    const vipThreshold = config.vipThreshold;
    
    if (!vipCode || vipCode.trim() === '') return;

    isVerifyingVip = true;
    const attemptKey = 'lx_vip_attempt_' + vipCode.toUpperCase();

    try {
      const cartRes = await fetch(window.Shopify.routes.root + 'cart.js');
      const cart = await cartRes.json();
      
      const cartTotal = cart.total_price;
      const appliedDiscounts = cart.cart_level_discount_applications.map(d => d.title.toUpperCase());
      const hasVipCode = appliedDiscounts.includes(vipCode.toUpperCase());
      const manualCode = localStorage.getItem('lx_coupon_code');
      
      // LOGIC 1: Cart is above threshold, but code is NOT applied -> Try to apply it.
      if (cartTotal >= vipThreshold && !hasVipCode) {
        const attemptStatus = sessionStorage.getItem(attemptKey);
        if (attemptStatus === 'trying') {
          sessionStorage.setItem(attemptKey, 'failed');
          return;
        } else if (attemptStatus === 'failed') {
          return;
        }

        sessionStorage.setItem(attemptKey, 'trying');

        let combinedCodes = vipCode;
        if (manualCode && manualCode.toUpperCase() !== vipCode.toUpperCase()) {
          combinedCodes += ',' + manualCode;
        }

        await fetch(window.Shopify.routes.root + 'cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ discount: combinedCodes })
        });
        
        if (isInitialLoad) {
          location.reload();
        } else {
          refreshCartUI();
        }
      } 
      // LOGIC 2: Successfully applied -> Clear flags
      else if (cartTotal >= vipThreshold && hasVipCode) {
        sessionStorage.removeItem(attemptKey);
        const errorNotice = document.getElementById('lx-vip-error-notice');
        if (errorNotice) errorNotice.style.display = 'none';
      }
      // LOGIC 3: Cart dropped below threshold, but VIP is still applied -> Remove it.
      else if (cartTotal < vipThreshold && hasVipCode) {
        await fetch(window.Shopify.routes.root + 'cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ discount: manualCode || '' }) 
        });
        sessionStorage.removeItem(attemptKey);
        
        if (isInitialLoad) {
          location.reload();
        } else {
          refreshCartUI();
        }
      }
      // LOGIC 4: Cart is below threshold and it is correctly not applied -> Clear flags.
      else if (cartTotal < vipThreshold && !hasVipCode) {
         sessionStorage.removeItem(attemptKey);
      }
    } catch (err) {
      console.error('VIP Verification Error:', err);
    } finally {
      isVerifyingVip = false;
    }
  }

  function refreshCartUI() {
    const drawerItems = document.querySelector('cart-drawer-items');
    const cartItems = document.querySelector('cart-items');
    if (drawerItems) {
      drawerItems.onCartUpdate();
    }
    if (cartItems) {
      cartItems.onCartUpdate();
    }
  }

  // Check state on initial page load
  document.addEventListener('DOMContentLoaded', function () {
    verifyVipState(true);
  });

  // Intercept AJAX cart updates (when user changes quantity + / - or changes variants)
  const originalFetch = window.fetch;
  window.fetch = async function() {
    const response = await originalFetch.apply(this, arguments);
    const url = arguments[0];
    
    if (typeof url === 'string' && (url.includes('/cart/change') || url.includes('/cart/add') || url.includes('/cart/update'))) {
      setTimeout(() => {
        verifyVipState(false);
      }, 400); 
    }
    return response;
  };
  
  window.lxRefreshCartUI = refreshCartUI;
})();
</script>
