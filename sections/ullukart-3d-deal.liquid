{% schema %}
{
  "name": "Luxe Swipe Deal",
  "settings": [
    {
      "type": "header",
      "content": "✨ Typography Settings"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading Font",
      "default": "playfair_display_n4"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body Font",
      "default": "lato_n4"
    },
    {
      "type": "header",
      "content": "🎨 Aesthetics"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "EXCLUSIVES"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Unlock limited-time privileges"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#FAFAFA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Main Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Luxury Accent (Gold/Champagne)",
      "default": "#C5A059"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Unlocked Button Color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Unlocked Button Text",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "sec",
      "label": "Auto-Swipe Speed",
      "default": 4
    },
    {
      "type": "header",
      "content": "⏳ Urgency Settings"
    },
    {
      "type": "number",
      "id": "timer_hours",
      "label": "Countdown Hours",
      "default": 12
    },
    {
      "type": "header",
      "content": "📐 Layout & Borders"
    },
    {
      "type": "checkbox",
      "id": "show_luxury_border",
      "label": "Enable Luxury Border Frame",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Vertical Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "deal",
      "name": "Luxury Product",
      "limit": 8,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxe Swipe Deal",
      "blocks": [
        { "type": "deal" },
        { "type": "deal" },
        { "type": "deal" }
      ]
    }
  ]
}
{% endschema %}

{%- assign heading_font = section.settings.heading_font -%}
{%- assign body_font = section.settings.body_font -%}

<style>
  /* Load Custom Fonts */
  {{ heading_font | font_face: font_display: 'swap' }}
  {{ body_font | font_face: font_display: 'swap' }}

  #luxe-wrapper-{{ section.id }} {
    --font-heading: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    --font-body: {{ body_font.family }}, {{ body_font.fallback_families }};
    --color-bg: {{ section.settings.bg_color }};
    --color-text: {{ section.settings.text_color }};
    --color-accent: {{ section.settings.accent_color }};
    --color-btn-bg: {{ section.settings.btn_bg_color }};
    --color-btn-text: {{ section.settings.btn_text_color }};
    --padding-y: {{ section.settings.padding_vertical }}px;
    
    background-color: var(--color-bg);
    padding: var(--padding-y) 20px;
    font-family: var(--font-body);
    overflow: hidden;
    color: var(--color-text);
    position: relative;
  }

  /* Luxury Inner Frame Border */
  {% if section.settings.show_luxury_border %}
  #luxe-wrapper-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: 15px;
    left: 15px;
    right: 15px;
    bottom: 15px;
    border: 1px solid var(--color-accent);
    opacity: 0.4;
    pointer-events: none;
    z-index: 1;
  }
  {% endif %}

  .luxe-header {
    text-align: center;
    margin-bottom: 30px;
    position: relative;
    z-index: 2;
  }

  .luxe-heading {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 400;
    margin: 0 0 8px 0;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: var(--color-text);
  }

  .luxe-subheading {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-accent);
    margin: 0;
  }

  /* Refined Countdown Timer */
  .luxe-timer-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    margin-bottom: 40px;
    position: relative;
    z-index: 2;
  }
  
  .luxe-timer-box {
    background: transparent;
    border: 1px solid rgba(0,0,0,0.1);
    color: var(--color-text);
    padding: 12px 14px;
    font-family: var(--font-heading);
    font-weight: 300;
    font-size: 22px;
    min-width: 55px;
    text-align: center;
    position: relative;
    box-shadow: inset 0 0 20px rgba(255,255,255,0.5);
  }

  .luxe-timer-colon {
    font-weight: 300;
    font-size: 20px;
    color: var(--color-accent);
  }

  .luxe-timer-label {
    display: block;
    font-family: var(--font-body);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #888;
    margin-top: 4px;
  }

  /* Slider Area */
  .luxe-slider-wrap {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 1 / 1;
    position: relative;
    margin: 0 auto 20px auto;
    background: radial-gradient(circle, rgba(255,255,255,0.8) 0%, rgba(255,255,255,0) 70%);
    border-radius: 50%;
    z-index: 2;
  }

  .luxe-track {
    display: flex;
    width: 100%;
    height: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .luxe-track::-webkit-scrollbar { display: none; }

  .luxe-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    scroll-snap-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    box-sizing: border-box;
    transition: opacity 0.5s ease;
  }

  .luxe-slide img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: drop-shadow(0px 20px 30px rgba(0,0,0,0.08));
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }
  
  .luxe-slide:hover img {
    transform: scale(1.05);
  }

  /* Elegant Dots */
  .luxe-dots {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 10px;
    position: relative;
    z-index: 2;
  }
  .luxe-dot { 
    width: 6px; 
    height: 6px; 
    border-radius: 50%; 
    background: transparent; 
    border: 1px solid var(--color-accent);
    transition: all 0.4s ease; 
    cursor: pointer; 
  }
  .luxe-dot.is-active { 
    background: var(--color-accent); 
    transform: scale(1.3);
  }

  /* Product Info */
  .luxe-text-area {
    text-align: center;
    max-width: 400px;
    margin: 30px auto 0;
    transition: opacity 0.4s ease, transform 0.4s ease;
    position: relative;
    z-index: 2;
  }
  .luxe-text-area.is-fading {
    opacity: 0;
    transform: translateY(10px);
  }

  .luxe-title {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    margin: 0 0 15px 0;
    line-height: 1.4;
    color: var(--color-text);
  }

  /* Price Reveal */
  .luxe-price-row {
    margin-bottom: 25px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    height: 40px;
  }

  .luxe-locked-text {
    font-size: 20px;
    font-weight: 300;
    color: #A0A0A0;
    letter-spacing: 6px;
  }

  .luxe-unlocked-text {
    font-family: var(--font-heading);
    font-size: 26px;
    font-weight: 400;
    color: var(--color-accent);
    animation: fadeUp 0.6s ease forwards;
  }

  .luxe-compare {
    font-size: 14px;
    color: #A0A0A0;
    text-decoration: line-through;
    font-weight: 300;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .luxe-compare.is-visible {
    opacity: 1;
  }

  @keyframes fadeUp {
    0% { transform: translateY(10px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  /* Luxury Button */
  .luxe-btn {
    display: inline-block;
    width: 100%;
    max-width: 320px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    text-transform: uppercase;
    text-align: center;
    text-decoration: none;
    padding: 18px 24px;
    letter-spacing: 2px;
    transition: all 0.4s ease;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  /* Locked State = Elegant Outline */
  .luxe-btn.is-locked {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-text);
  }

  .luxe-btn.is-locked:hover {
    background: rgba(0,0,0,0.03);
  }

  /* Unlocked State = Solid Premium */
  .luxe-btn.is-unlocked {
    background: var(--color-btn-bg);
    color: var(--color-btn-text);
    border: 1px solid var(--color-btn-bg);
  }

  .luxe-btn.is-unlocked:hover {
    opacity: 0.9;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  /* Timer Pulse for PC */
  @keyframes luxe-pulse {
    0% { box-shadow: inset 0 0 20px rgba(255,255,255,0.5); }
    50% { box-shadow: inset 0 0 30px rgba(197,160,89,0.4), 0 0 15px rgba(197,160,89,0.3); border-color: rgba(197,160,89,0.5); }
    100% { box-shadow: inset 0 0 20px rgba(255,255,255,0.5); }
  }

  /* PC Refinements */
  @media (min-width: 769px) {
    #luxe-wrapper-{{ section.id }} {
      max-width: 1000px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      grid-template-areas: 
        "header slider"
        "timer slider"
        ". dots"
        ". textarea";
      align-items: center;
      gap: 20px 40px;
      padding: 80px 50px;
      background: radial-gradient(circle at left, #ffffff 0%, var(--color-bg) 80%);
      border-radius: 20px;
      box-shadow: 0 20px 50px rgba(0,0,0,0.03);
    }
    
    .luxe-timer-box { animation: luxe-pulse 2.5s infinite ease-in-out; }
    
    .luxe-header { grid-area: header; text-align: left; margin-bottom: 0; align-self: end; }
    .luxe-timer-wrap { grid-area: timer; justify-content: flex-start; margin-bottom: 0; align-self: start; }
    
    /* Move text area to the right column below slider */
    .luxe-text-area { grid-area: textarea; text-align: center; margin: 0 auto; max-width: 400px; }
    .luxe-price-row { justify-content: center; }
    
    .luxe-slider-wrap { grid-area: slider; margin: 0 auto; max-width: 500px; width: 100%; align-self: center; position: relative; }
    .luxe-dots { grid-area: dots; margin-top: 10px; justify-content: center; }
  }

  /* Carousel Arrows */
  .luxe-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: var(--color-text);
    color: var(--color-bg);
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    transition: all 0.3s ease;
    opacity: 0.8;
  }
  .luxe-arrow:hover { opacity: 1; transform: translateY(-50%) scale(1.1); }
  .luxe-arrow.prev { left: -20px; }
  .luxe-arrow.next { right: -20px; }
  @media (max-width: 768px) {
    .luxe-arrow { display: none; } /* Hide arrows on mobile where touch swipe is natural */
  }
</style>

<div class="luxe-wrapper pc-reveal" id="luxe-wrapper-{{ section.id }}" data-speed="{{ section.settings.autoplay_speed | times: 1000 }}" data-timer="{{ section.settings.timer_hours }}">
  
  <div class="luxe-header pc-reveal-stagger">
    <h2 class="luxe-heading">{{ section.settings.heading }}</h2>
    <p class="luxe-subheading">{{ section.settings.subheading }}</p>
  </div>

  <div class="luxe-timer-wrap">
    <div class="luxe-timer-box">
      <span id="luxeHr-{{ section.id }}">00</span>
      <span class="luxe-timer-label">Hours</span>
    </div>
    <span class="luxe-timer-colon">:</span>
    <div class="luxe-timer-box">
      <span id="luxeMin-{{ section.id }}">00</span>
      <span class="luxe-timer-label">Mins</span>
    </div>
    <span class="luxe-timer-colon">:</span>
    <div class="luxe-timer-box">
      <span id="luxeSec-{{ section.id }}">00</span>
      <span class="luxe-timer-label">Secs</span>
    </div>
  </div>

  <div class="luxe-slider-wrap">
    <button class="luxe-arrow prev" id="luxePrev-{{ section.id }}" aria-label="Previous Deal"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
    <button class="luxe-arrow next" id="luxeNext-{{ section.id }}" aria-label="Next Deal"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg></button>
    <div class="luxe-track" id="luxeTrack-{{ section.id }}">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        <div class="luxe-slide" 
             data-index="{{ forloop.index0 }}"
             data-title="{{ product.title | default: 'The Signature Collection' | escape }}"
             data-price="{{ product.price | default: 99900 | money_without_trailing_zeros }}"
             data-compare="{% if product.compare_at_price > product.price %}{{ product.compare_at_price | money_without_trailing_zeros }}{% endif %}"
             data-url="{{ product.url | default: '#' }}"
             {{ block.shopify_attributes }}>
          {% if product != blank and product.featured_image %}
            <img src="{{ product.featured_image | img_url: '800x800' }}" alt="{{ product.title | escape }}" loading="lazy">
          {% else %}
            <div style="color: #A0A0A0; font-weight: 300; letter-spacing: 2px;">PRODUCT PREVIEW</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="luxe-dots" id="luxeDots-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="luxe-dot {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}"></div>
    {% endfor %}
  </div>

  <div class="luxe-text-area" id="luxeTextArea-{{ section.id }}">
    <h3 class="luxe-title" id="luxeTitle-{{ section.id }}">Loading...</h3>
    
    <div class="luxe-price-row">
      <span id="luxePrice-{{ section.id }}"><span class="luxe-locked-text">••••••</span></span>
      <span class="luxe-compare" id="luxeCompare-{{ section.id }}"></span>
    </div>

    <a href="#" class="luxe-btn is-locked" id="luxeBtn-{{ section.id }}">
      Unlock Privilege
    </a>
  </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const sectionId = '{{ section.id }}';
    const wrapper = document.getElementById('luxe-wrapper-' + sectionId);
    if (!wrapper) return;

    // --- 1. ELEGANT COUNTDOWN TIMER ---
    const timerHours = parseInt(wrapper.getAttribute('data-timer')) || 12;
    const hrEl = document.getElementById('luxeHr-' + sectionId);
    const minEl = document.getElementById('luxeMin-' + sectionId);
    const secEl = document.getElementById('luxeSec-' + sectionId);
    
    let endTime = localStorage.getItem('luxe_timer_' + sectionId);
    if (!endTime || new Date().getTime() > endTime) {
      endTime = new Date().getTime() + (timerHours * 60 * 60 * 1000);
      localStorage.setItem('luxe_timer_' + sectionId, endTime);
    }

    function updateTimer() {
      let now = new Date().getTime();
      let distance = endTime - now;
      if (distance < 0) {
        endTime = new Date().getTime() + (timerHours * 60 * 60 * 1000);
        localStorage.setItem('luxe_timer_' + sectionId, endTime);
        distance = endTime - now;
      }
      let h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      let m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      let s = Math.floor((distance % (1000 * 60)) / 1000);
      
      if(hrEl) hrEl.innerText = (h < 10 ? "0" : "") + h;
      if(minEl) minEl.innerText = (m < 10 ? "0" : "") + m;
      if(secEl) secEl.innerText = (s < 10 ? "0" : "") + s;
    }
    updateTimer(); 
    setInterval(updateTimer, 1000);

    // --- 2. ROBUST SLIDER LOGIC ---
    const track = document.getElementById('luxeTrack-' + sectionId);
    if (!track) return;
    
    const slides = track.querySelectorAll('.luxe-slide');
    const dots = document.querySelectorAll('#luxeDots-' + sectionId + ' .luxe-dot');
    
    const textArea = document.getElementById('luxeTextArea-' + sectionId);
    const titleEl = document.getElementById('luxeTitle-' + sectionId);
    const priceEl = document.getElementById('luxePrice-' + sectionId);
    const compareEl = document.getElementById('luxeCompare-' + sectionId);
    const btnEl = document.getElementById('luxeBtn-' + sectionId);
    
    const speed = parseInt(wrapper.getAttribute('data-speed')) || 4000;
    let currentIndex = 0;
    let autoPlayInterval = null;
    let swipeDirection = 1;
    let isPriceUnlocked = false; 

    if (slides.length < 1) return;

    // UNLOCK BUTTON LOGIC
    btnEl.addEventListener('click', function(e) {
      if (!isPriceUnlocked) {
        e.preventDefault(); 
        
        // Reveal Price
        const activeSlide = slides[currentIndex];
        priceEl.innerHTML = '<span class="luxe-unlocked-text">' + activeSlide.getAttribute('data-price') + '</span>';
        
        if (activeSlide.getAttribute('data-compare')) {
          compareEl.innerText = activeSlide.getAttribute('data-compare');
          compareEl.classList.add('is-visible');
        }

        // Transform Button to Add to Cart
        btnEl.classList.remove('is-locked');
        btnEl.classList.add('is-unlocked');
        btnEl.innerText = 'Add To Bag';
        btnEl.href = activeSlide.getAttribute('data-url');
        
        isPriceUnlocked = true;
        stopAutoPlay();
      }
    });

    function updateTextForSlide(index) {
      textArea.classList.add('is-fading');
      
      setTimeout(() => {
        const activeSlide = slides[index];
        titleEl.innerText = activeSlide.getAttribute('data-title');
        
        // Reset State
        isPriceUnlocked = false;
        priceEl.innerHTML = '<span class="luxe-locked-text">••••••</span>';
        compareEl.innerText = '';
        compareEl.classList.remove('is-visible');
        
        btnEl.classList.add('is-locked');
        btnEl.classList.remove('is-unlocked');
        btnEl.innerText = 'Unlock Privilege';
        btnEl.href = '#'; 
        
        textArea.classList.remove('is-fading');
      }, 400);
    }

    // Initialize Intersection Observer to reliably track the active slide
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const index = parseInt(entry.target.getAttribute('data-index'));
          if (index !== currentIndex) {
            currentIndex = index;
            dots.forEach(d => d.classList.remove('is-active'));
            if(dots[index]) dots[index].classList.add('is-active');
            updateTextForSlide(index);
          }
        }
      });
    }, {
      root: track,
      threshold: 0.6
    });

    slides.forEach(slide => observer.observe(slide));

    // Force initialization of the first slide text
    updateTextForSlide(0);

    function scrollToSlide(index) {
      if (slides[index]) {
        track.scrollTo({ left: slides[index].offsetLeft, behavior: 'smooth' });
      }
    }

    function autoScroll() {
      if (currentIndex >= slides.length - 1 && swipeDirection === 1) {
        swipeDirection = -1;
      } else if (currentIndex <= 0 && swipeDirection === -1) {
        swipeDirection = 1;
      }
      const nextIndex = currentIndex + swipeDirection;
      scrollToSlide(nextIndex);
    }

    function startAutoPlay() { 
        if (autoPlayInterval) clearInterval(autoPlayInterval);
        autoPlayInterval = setInterval(autoScroll, speed); 
    }
    
    function stopAutoPlay() { 
        if (autoPlayInterval) clearInterval(autoPlayInterval);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        stopAutoPlay();
        const clickedIndex = parseInt(e.target.getAttribute('data-index'));
        scrollToSlide(clickedIndex);
        if(!isPriceUnlocked) startAutoPlay();
      });
    });

    const prevBtn = document.getElementById('luxePrev-' + sectionId);
    const nextBtn = document.getElementById('luxeNext-' + sectionId);

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        stopAutoPlay();
        let nextIdx = currentIndex - 1;
        if (nextIdx < 0) nextIdx = slides.length - 1;
        scrollToSlide(nextIdx);
        if(!isPriceUnlocked) startAutoPlay();
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        stopAutoPlay();
        let nextIdx = currentIndex + 1;
        if (nextIdx >= slides.length) nextIdx = 0;
        scrollToSlide(nextIdx);
        if(!isPriceUnlocked) startAutoPlay();
      });
    }

    // Pause on Interaction (touch only to keep desktop auto-play reliable)
    track.addEventListener('touchstart', stopAutoPlay, {passive: true});
    track.addEventListener('touchend', () => { if(!isPriceUnlocked) startAutoPlay(); }, {passive: true});

    // Start auto-play initially
    startAutoPlay();
});
</script>