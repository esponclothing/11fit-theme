                              {%- endfor -%}
                              {%- if has_items == false -%}
                                <div class="slider-item dummy-placeholder">
                                   <h3 style="margin:0; font-size: 16px;">Banner Ready! ✅</h3>
                                   <p style="margin: 5px 0 0; font-size: 14px;">Add <strong>Slider Image Items</strong> in the Theme Editor and set their Campaign ID to: <strong>{{ target_campaign_id }}</strong></p>
                                </div>
                              {%- endif -%}
                            </div>
                          </li>
                        {%- endif -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                {% comment %} --- END INLINE SLIDER --- {% endcomment %}

                {%- assign skip_card_product_styles = true -%}
              {%- endfor -%}
            </ul>
            {%- endif -%}

            {%- if paginate.pages > 1 -%}
              {% render 'pagination', paginate: paginate, anchor: '' %}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}

  {% comment %} --- CUSTOM SCROLL ANIMATION SCRIPT --- {% endcomment %}
  <script>
    (function() {
      window.copyCouponCode = function(element, code) {
        if (!navigator.clipboard) return;
        navigator.clipboard.writeText(code).then(() => {
          const originalHTML = element.innerHTML;
          element.innerHTML = "Copied! ✓";
          const originalBG = element.style.background;
          const originalBorder = element.style.borderColor;
          element.style.background = "#10B981"; // Emerald green
          element.style.borderColor = "#10B981";
          setTimeout(() => {
            element.innerHTML = originalHTML;
            element.style.background = originalBG;
            element.style.borderColor = originalBorder;
          }, 2000);
        });
      };

      function initCustomReveal() {
        const observer = new IntersectionObserver((entries, obs) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              obs.unobserve(entry.target);
            }
          });
        }, {
          threshold: 0.05,
          rootMargin: "0px 0px 50px 0px"
        });

        const elements = document.querySelectorAll('.custom-fade-in-up:not(.is-visible)');
        elements.forEach(el => observer.observe(el));
      }

      initCustomReveal();

      document.addEventListener('shopify:section:load', initCustomReveal);
      
      const gridContainer = document.getElementById('ProductGridContainer');
      if (gridContainer) {
        const mutationObserver = new MutationObserver(() => {
          initCustomReveal();
        });
        mutationObserver.observe(gridContainer, { childList: true, subtree: true });
      }
    })();
  </script>
</div>

