              <style>
                /* Dot indicators for swipe sliders */
                .slider-dots {
                  display: flex;
                  justify-content: center;
                  gap: 6px;
                  margin-top: 10px;
                  padding: 4px 0;
                }
                .slider-dot {
                  width: 7px;
                  height: 7px;
                  border-radius: 50%;
                  background: rgba(255,255,255,0.35);
                  border: none;
                  padding: 0;
                  cursor: pointer;
                  transition: background 0.25s, transform 0.25s;
                  flex-shrink: 0;
                }
                .slider-dot.active {
                  background: #fff;
                  transform: scale(1.3);
                }
                /* Offer carousel dots */
                .offer-carousel-dots {
                  display: flex;
                  justify-content: center;
                  gap: 6px;
                  margin-top: 8px;
                  padding: 2px 0;
                }
                .offer-carousel-dot {
                  width: 6px;
                  height: 6px;
                  border-radius: 50%;
                  background: rgba(255,255,255,0.4);
                  border: none;
                  padding: 0;
                  cursor: pointer;
                  transition: background 0.25s, transform 0.25s;
                }
                .offer-carousel-dot.active {
                  background: #fff;
                  transform: scale(1.3);
                }
              </style>
              <script>
                /* --- Smooth scroll helper (no auto-play) --- */
                function snappyScroll(slider, direction, amount) {
                  const start = slider.scrollLeft;
                  const target = direction === 'left'
                    ? Math.max(0, start - amount)
                    : Math.min(slider.scrollWidth - slider.clientWidth, start + amount);
                  const startTime = performance.now();
                  const duration = 350;
                  function easeOut(t) { return 1 - Math.pow(1 - t, 3); }
                  function step(now) {
                    const progress = Math.min((now - startTime) / duration, 1);
                    slider.scrollLeft = start + (target - start) * easeOut(progress);
                    if (progress < 1) requestAnimationFrame(step);
                  }
                  requestAnimationFrame(step);
                }

                function slideCategory(handle, direction) {
                  const slider = document.getElementById('slider-' + handle);
                  if (!slider) return;
                  const firstItem = slider.querySelector('.slider-item');
                  const itemWidth = firstItem ? firstItem.offsetWidth + 8 : slider.clientWidth * 0.7;
                  snappyScroll(slider, direction, itemWidth);
                }

                /* --- Build dot indicators for a slider --- */
                function buildDots(slider, dotsContainer, itemSelector) {
                  if (!slider || !dotsContainer) return;
                  const items = slider.querySelectorAll(itemSelector);
                  if (items.length <= 1) { dotsContainer.style.display = 'none'; return; }
                  dotsContainer.innerHTML = '';
                  items.forEach((_, i) => {
                    const dot = document.createElement('button');
                    dot.className = 'slider-dot' + (i === 0 ? ' active' : '');
                    dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
                    dot.addEventListener('click', () => {
                      const itemW = items[0].offsetWidth + 8;
                      slider.scrollLeft = i * itemW;
                    });
                    dotsContainer.appendChild(dot);
                  });

                  // Update active dot on scroll
                  slider.addEventListener('scroll', () => {
                    const itemW = items[0].offsetWidth + 8;
                    const idx = Math.round(slider.scrollLeft / itemW);
                    dotsContainer.querySelectorAll('.slider-dot').forEach((d, i) => {
                      d.classList.toggle('active', i === idx);
                    });
                  }, { passive: true });
                }

                /* --- Touch drag scroll support --- */
                function addDragScroll(el) {
                  let isDown = false, startX, scrollStart;
                  el.addEventListener('mousedown', e => {
                    isDown = true; startX = e.pageX; scrollStart = el.scrollLeft;
                    el.style.cursor = 'grabbing';
                  });
                  window.addEventListener('mouseup', () => { isDown = false; el.style.cursor = ''; });
                  el.addEventListener('mousemove', e => {
                    if (!isDown) return;
                    e.preventDefault();
                    el.scrollLeft = scrollStart - (e.pageX - startX);
                  });
                }

                function initCollectionSliders() {
                  /* Product sliders (category rows) */
                  document.querySelectorAll('.category-swipe-slider, .custom-inline-slider').forEach(slider => {
                    addDragScroll(slider);
                    const dotsEl = document.getElementById('dots-' + slider.id.replace('slider-', ''));
                    if (dotsEl) buildDots(slider, dotsEl, '.slider-item');
                  });

                  /* Offer/banner carousels - dots only, no auto-play */
                  document.querySelectorAll('.offer-carousel-wrapper').forEach(carousel => {
                    addDragScroll(carousel);
                    // Build dots below carousel
                    let dotsEl = carousel.nextElementSibling;
                    if (!dotsEl || !dotsEl.classList.contains('offer-carousel-dots')) {
                      dotsEl = document.createElement('div');
                      dotsEl.className = 'offer-carousel-dots';
                      carousel.parentNode.insertBefore(dotsEl, carousel.nextSibling);
                    }
                    const boxes = carousel.querySelectorAll('.lucrative-offer-box');
                    if (boxes.length > 1) {
                      boxes.forEach((_, i) => {
                        const dot = document.createElement('button');
                        dot.className = 'offer-carousel-dot' + (i === 0 ? ' active' : '');
                        dot.setAttribute('aria-label', 'Slide ' + (i + 1));
                        dot.addEventListener('click', () => {
                          const w = boxes[0].offsetWidth + 8;
                          carousel.scrollLeft = i * w;
                        });
                        dotsEl.appendChild(dot);
                      });
                      carousel.addEventListener('scroll', () => {
                        const w = boxes[0].offsetWidth + 8;
                        const idx = Math.round(carousel.scrollLeft / w);
                        dotsEl.querySelectorAll('.offer-carousel-dot').forEach((d, i) => {
                          d.classList.toggle('active', i === idx);
                        });
                      }, { passive: true });
                    }
                  });
                }

                if (document.readyState === 'loading') {
                  document.addEventListener('DOMContentLoaded', initCollectionSliders);
                } else {
                  initCollectionSliders();
                }
              </script>
