{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
  {%- paginate collection.products by section.settings.products_per_page -%}
    {%- if section.settings.enable_sorting and section.settings.filter_type == 'vertical' -%}
      <facet-filters-form class="facets facets-vertical-sort page-width small-hide pc-reveal">
        <form class="facets-vertical-form" id="FacetSortForm">
          <div class="facet-filters sorting caption">
            <div class="facet-filters__field">
              <h2 class="facet-filters__label caption-large text-body">
                <label for="SortBy">{{ 'products.facets.sort_by_label' | t }}</label>
              </h2>
              <div class="select">
                {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                <select
                  name="sort_by"
                  class="facet-filters__sort select__select caption-large"
                  id="SortBy"
                  aria-describedby="a11y-refresh-page-message"
                >
                  {%- for option in collection.sort_options -%}
                    <option
                      value="{{ option.value | escape }}"
                      {% if option.value == sort_by %}selected="selected"{% endif %}
                    >
                      {{ option.name | escape }}
                    </option>
                  {%- endfor -%}
                </select>
                <span class="svg-wrapper">
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </span>
              </div>
            </div>
          </div>

          <div class="product-count-vertical light" role="status">
            <h2 class="product-count__text text-body">
              <span id="ProductCountDesktop">
                {%- if collection.results_count -%}
                  {{ 'templates.search.results_with_count' | t: terms: collection.terms, count: collection.results_count }}
                {%- elsif collection.products_count == collection.all_products_count -%}
                  {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
                {%- else -%}
                  {{ 'products.facets.product_count' | t: product_count: collection.products_count, count: collection.all_products_count }}
                {%- endif -%}
              </span>
            </h2>
            {%- render 'loading-spinner' -%}
          </div>
        </form>
      </facet-filters-form>
    {%- endif -%}

    <div class="{% if section.settings.filter_type == 'vertical' %} facets-vertical page-width{% endif %}">
      {{ 'component-facets.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
      {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
        <aside
          aria-labelledby="verticalTitle"
          class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
          id="main-collection-filters"
          data-id="{{ section.id }}"
        >
          {% render 'facets',
            results: collection,
            enable_filtering: section.settings.enable_filtering,
            enable_sorting: section.settings.enable_sorting,
            filter_type: section.settings.filter_type,
            paginate: paginate
          %}
        </aside>
      {%- endif -%}

      <div class="product-grid-container" id="ProductGridContainer">
        {%- if collection.products.size == 0 -%}
          <div class="collection collection--empty page-width" id="product-grid" data-id="{{ section.id }}">
            <div class="loading-overlay gradient"></div>
            <div class="title-wrapper center">
              <h2 class="title title--primary">
                {{ 'sections.collection_template.empty' | t -}}<br>
                {{ 'sections.collection_template.use_fewer_filters_html' | t: link: collection.url, class: 'underlined-link link' }}
              </h2>
            </div>
          </div>
        {%- else -%}
          <div class="collection{% if section.settings.filter_type != 'vertical' %} page-width{% endif %} pc-reveal">
            <div class="loading-overlay gradient"></div>
            <style>
              /* --- FIX FOR INVISIBLE PRODUCTS ON LOAD --- */
              #ProductGridContainer, 
              #ProductGridContainer .scroll-trigger,
              #ProductGridContainer .grid__item,
              .pc-reveal {
                opacity: 1 !important;
                transform: none !important;
                animation: none !important;
                visibility: visible !important;
              }

              .fit-premium-grid {
                display: grid !important;
                grid-template-columns: repeat(2, 1fr) !important;
                column-gap: 8px !important;
                row-gap: 16px !important;
              }
              .fit-premium-grid .grid__item {
                width: 100% !important;
                max-width: 100% !important;
                margin: 0 !important;
                padding: 0 !important;
                min-width: 0 !important;
              }
              .fit-premium-grid .card-wrapper {
                height: auto !important;
                display: block !important;
              }
              .fit-premium-grid .card {
                --image-padding: 0 !important;
                border-radius: 8px !important;
                overflow: hidden !important;
                border: none !important;
                background-color: transparent !important;
                margin: 0 !important;
                padding: 0 !important;
              }
              .fit-premium-grid .card__inner {
                border-radius: 8px !important;
                background-color: #f8f8f8 !important;
                --ratio-percent: 125% !important;
                margin: 0 !important;
                padding: 0 !important;
                width: 100% !important;
              }
              .fit-premium-grid .card__inner::before {
                padding-bottom: 125% !important;
              }
              .fit-premium-grid .card__media {
                margin: 0 !important;
                padding: 0 !important;
                width: 100% !important;
                height: 100% !important;
              }
              .fit-premium-grid .media {
                margin: 0 !important;
                padding: 0 !important;
                width: 100% !important;
                height: 100% !important;
              }
              .fit-premium-grid .media img {
                object-fit: cover !important;
                object-position: center top !important;
                width: 100% !important;
                height: 100% !important;
                margin: 0 !important;
                padding: 0 !important;
                left: 0 !important;
                top: 0 !important;
              }

              /* --- INLINE SLIDER CSS --- */
              .collection-slider-full-width {
                grid-column: 1 / -1 !important; 
                width: 100% !important;
                margin: 16px 0 24px 0 !important;
                overflow: hidden;
              }

              /* Offer Carousel (Swipeable Banners) */
              .offer-carousel-wrapper {
                display: flex;
                overflow-x: auto;
                gap: 8px;
                scroll-snap-type: x mandatory;
                scrollbar-width: none; 
                -ms-overflow-style: none; 
                margin-bottom: 16px;
                padding-bottom: 4px;
              }
              .offer-carousel-wrapper::-webkit-scrollbar { display: none; }
              
              /* Premium Creative Offer Box */
              .lucrative-offer-box {
                flex: 0 0 92%; 
                scroll-snap-align: center;
                border-radius: 8px;
                padding: 16px 20px; 
                display: flex;
                align-items: center;
                justify-content: space-between;
                box-shadow: 0 4px 15px rgba(0,0,0,0.05);
                position: relative;
                overflow: hidden;
                border: 1px solid rgba(255,255,255,0.1);
              }
              @media screen and (min-width: 750px) {
                .lucrative-offer-box { flex: 0 0 100%; }
              }
              .lucrative-offer-box::before {
                content: '';
                position: absolute;
                top: 0; left: -100%;
                width: 50%; height: 100%;
                background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0) 100%);
                transform: skewX(-20deg);
                animation: luxury-shine 6s infinite;
              }
              @keyframes luxury-shine {
                0% { left: -100%; }
                20% { left: 200%; }
                100% { left: 200%; }
              }
              .lucrative-offer-content {
                z-index: 2;
                display: flex;
                flex-direction: column;
                justify-content: center;
              }
              .lucrative-offer-heading {
                font-size: 1.8rem;
                font-weight: 800;
                margin: 0 0 2px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                line-height: 1.1;
              }
              .lucrative-offer-sub {
                font-size: 1.3rem;
                font-weight: 400;
                margin: 0;
                opacity: 0.9;
              }
              .lucrative-offer-coupon {
                z-index: 2;
                background: rgba(0,0,0,0.25);
                border: 1px dashed rgba(255,255,255,0.4);
                padding: 6px 12px;
                border-radius: 4px;
                font-weight: 700;
                font-size: 1.2rem;
                letter-spacing: 1px;
                backdrop-filter: blur(8px);
                text-transform: uppercase;
                white-space: nowrap;
              }

              /* Product Scrollable Area */
              .custom-inline-slider {
                display: flex;
                overflow-x: auto;
                gap: 12px;
                scroll-snap-type: x mandatory;
                scrollbar-width: none; 
                -ms-overflow-style: none; 
                padding-bottom: 10px;
              }
              .custom-inline-slider::-webkit-scrollbar { display: none; }
              .custom-inline-slider .slider-item {
                flex: 0 0 65vw; 
                max-width: 300px;
                scroll-snap-align: start;
                border-radius: 8px;
                overflow: hidden;
              }
              .slider-item-img-wrapper {
                border-radius: 8px;
                overflow: hidden;
                background: #f8f8f8;
                aspect-ratio: 4/5; 
              }
              .custom-inline-slider .slider-item img {
                width: 100%;
                height: 100%;
                display: block;
                object-fit: cover;
              }
              
              /* Editable Product Details Typography */
              .slider-item-details {
                padding: 12px 2px 0 2px;
                text-align: left;
              }
              .slider-item-title {
                font-size: var(--title-size, 1.4rem);
                font-weight: 500;
                margin-bottom: 4px;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
                color: rgb(var(--color-foreground));
                letter-spacing: 0.2px;
              }
              .slider-item-price-row {
                display: flex;
                align-items: center;
                flex-wrap: wrap;
                gap: 6px;
                margin-bottom: 4px;
              }
              .slider-item-price {
                font-weight: 800; 
                font-size: var(--price-size, 1.5rem);
                color: rgb(var(--color-foreground));
              }
              .slider-item-compare {
                text-decoration: line-through;
                font-size: calc(var(--price-size, 1.5rem) * 0.8); 
                color: rgba(var(--color-foreground), 0.5);
              }
              .slider-item-discount {
                font-size: var(--discount-size, 1.1rem);
                font-weight: 800;
                color: #d82a2a; 
                background: #ffebeb; 
                padding: 2px 6px;
                border-radius: 4px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
              }
              .slider-item-rating {
                font-size: 1.2rem;
                color: rgba(var(--color-foreground), 0.7);
                display: flex;
                align-items: center;
                gap: 4px;
                font-weight: 500;
              }
              .slider-item-rating svg {
                width: 13px;
                height: 13px;
                fill: #FFD700;
              }

              .dummy-placeholder {
                background: #f4f4f4;
                padding: 40px 20px;
                text-align: center;
                border: 2px dashed #ccc;
                width: 100%;
                max-width: 100% !important;
                flex: 0 0 100% !important;
              }

              @media (max-width: 450px) {
                .lucrative-offer-box {
                  padding: 12px 14px;
                }
                .lucrative-offer-heading { font-size: 1.5rem; }
                .lucrative-offer-sub { font-size: 1.1rem; }
                .lucrative-offer-coupon { font-size: 1.0rem; padding: 4px 8px; }
              }

              @media screen and (min-width: 750px) {
                .fit-premium-grid {
                  grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr) !important;
                  column-gap: 24px !important;
                  row-gap: 40px !important;
                }
                .custom-inline-slider .slider-item {
                  flex: 0 0 25vw; 
                }
              }
            </style>
            
            <ul
              id="product-grid"
              data-id="{{ section.id }}"
              class="grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop fit-premium-grid"
            >
              {% assign skip_card_product_styles = false %}
              {%- for product in collection.products -%}
                {% assign lazy_load = false %}
                {%- if forloop.index > 2 -%}{%- assign lazy_load = true -%}{%- endif -%}
                {% assign current_product_index = forloop.index %}

                <li class="grid__item">
                  {% render 'card-product',
                    card_product: product,
                    media_aspect_ratio: section.settings.image_ratio,
                    image_shape: section.settings.image_shape,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    lazy_load: lazy_load,
                    skip_styles: skip_card_product_styles,
                    quick_add: section.settings.quick_add,
                    section_id: section.id
                  %}
                </li>

                {% comment %} --- INLINE SLIDER INJECTION (DYNAMIC BY CAMPAIGN BLOCKS) --- {% endcomment %}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'slider_campaign' and block.settings.insert_after == current_product_index -%}
                    
                    {%- assign show_campaign = true -%}
                    {%- if block.settings.target_collection != blank and block.settings.target_collection.handle != collection.handle -%}
                      {%- assign show_campaign = false -%}
                    {%- endif -%}

                    {%- if show_campaign -%}
                      <li class="grid__item collection-slider-full-width" {{ block.shopify_attributes }}>
                        
                        {% comment %} Offer Banner Carousel (Supports up to 3 slides) {% endcomment %}
                        <div class="offer-carousel-wrapper">
                          
                          {%- if block.settings.heading_1 != blank -%}
                          <div class="lucrative-offer-box" style="background: linear-gradient(135deg, {{ block.settings.bg_color_1 }}, {{ block.settings.bg_color_2 }}); color: {{ block.settings.text_color }}; min-height: {{ block.settings.offer_box_height }}px;">
                            <div class="lucrative-offer-content">
                              <h3 class="lucrative-offer-heading" style="color: {{ block.settings.text_color }};">{{ block.settings.heading_1 }}</h3>
                              <p class="lucrative-offer-sub" style="color: {{ block.settings.text_color }};">{{ block.settings.subheading_1 }}</p>
                            </div>
                            {%- if block.settings.coupon_code_1 != blank -%}
                              <div class="lucrative-offer-coupon" style="color: {{ block.settings.text_color }};">Code: <span>{{ block.settings.coupon_code_1 }}</span></div>
                            {%- endif -%}
                          </div>
                          {%- endif -%}

                          {%- if block.settings.heading_2 != blank -%}
                          <div class="lucrative-offer-box" style="background: linear-gradient(135deg, {{ block.settings.bg_color_1 }}, {{ block.settings.bg_color_2 }}); color: {{ block.settings.text_color }}; min-height: {{ block.settings.offer_box_height }}px;">
                            <div class="lucrative-offer-content">
                              <h3 class="lucrative-offer-heading" style="color: {{ block.settings.text_color }};">{{ block.settings.heading_2 }}</h3>
                              <p class="lucrative-offer-sub" style="color: {{ block.settings.text_color }};">{{ block.settings.subheading_2 }}</p>
                            </div>
                            {%- if block.settings.coupon_code_2 != blank -%}
                              <div class="lucrative-offer-coupon" style="color: {{ block.settings.text_color }};">Code: <span>{{ block.settings.coupon_code_2 }}</span></div>
                            {%- endif -%}
                          </div>
                          {%- endif -%}

                          {%- if block.settings.heading_3 != blank -%}
                          <div class="lucrative-offer-box" style="background: linear-gradient(135deg, {{ block.settings.bg_color_1 }}, {{ block.settings.bg_color_2 }}); color: {{ block.settings.text_color }}; min-height: {{ block.settings.offer_box_height }}px;">
                            <div class="lucrative-offer-content">
                              <h3 class="lucrative-offer-heading" style="color: {{ block.settings.text_color }};">{{ block.settings.heading_3 }}</h3>
                              <p class="lucrative-offer-sub" style="color: {{ block.settings.text_color }};">{{ block.settings.subheading_3 }}</p>
                            </div>
                            {%- if block.settings.coupon_code_3 != blank -%}
                              <div class="lucrative-offer-coupon" style="color: {{ block.settings.text_color }};">Code: <span>{{ block.settings.coupon_code_3 }}</span></div>
                            {%- endif -%}
                          </div>
                          {%- endif -%}

                        </div>

                        {% comment %} Matched Product Slider Items {% endcomment %}
                        <div class="custom-inline-slider" style="--title-size: {{ block.settings.font_size_title }}rem; --price-size: {{ block.settings.font_size_price }}rem; --discount-size: {{ block.settings.font_size_discount }}rem;">
                          {% assign has_items = false %}
                          {% assign target_campaign_id = block.settings.campaign_id %}
                          
                          {%- for item in section.blocks -%}
                            {%- if item.type == 'slider_item' and item.settings.campaign_id == target_campaign_id -%}
                              
                              {%- assign show_item = true -%}
                              {%- if item.settings.target_collection != blank and item.settings.target_collection.handle != collection.handle -%}
                                {%- assign show_item = false -%}
                              {%- endif -%}

                              {%- if show_item -%}
                                {% assign has_items = true %}
                                
                                <div class="slider-item" {{ item.shopify_attributes }}>
                                  <a href="{{ item.settings.link | default: '#' }}" style="text-decoration: none; color: inherit;">
                                    
                                    <div class="slider-item-img-wrapper">
                                      {%- if item.settings.image != blank -%}
                                        {{ item.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                                      {%- else -%}
                                        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                      {%- endif -%}
                                    </div>
                                    
                                    <div class="slider-item-details">
                                      {%- if item.settings.title != blank -%}
                                        <div class="slider-item-title">{{ item.settings.title }}</div>
                                      {%- endif -%}
                                      
                                      <div class="slider-item-price-row">
                                        {%- if item.settings.price != blank -%}
                                          <span class="slider-item-price">{{ item.settings.price }}</span>
                                        {%- endif -%}
                                        {%- if item.settings.compare_price != blank -%}
                                          <span class="slider-item-compare">{{ item.settings.compare_price }}</span>
                                        {%- endif -%}
                                        {%- if item.settings.discount != blank -%}
                                          <span class="slider-item-discount">{{ item.settings.discount }}</span>
                                        {%- endif -%}
                                      </div>
                                      
                                      {%- if item.settings.rating != blank -%}
                                        <div class="slider-item-rating">
                                          <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                          {{ item.settings.rating }}
                                        </div>
                                      {%- endif -%}
                                    </div>

                                  </a>
                                </div>
                              {%- endif -%}

                            {%- endif -%}
                          {%- endfor -%}

                          {%- if has_items == false -%}
                            <div class="slider-item dummy-placeholder">
                               <h3 style="margin:0; font-size: 16px;">Banner Ready! ✅</h3>
                               <p style="margin: 5px 0 0; font-size: 14px;">Add <strong>Slider Image Items</strong> in the Theme Editor and set their Campaign ID to: <strong>{{ target_campaign_id }}</strong></p>
                            </div>
                          {%- endif -%}
                        </div>

                      </li>
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
                {% comment %} --- END INLINE SLIDER --- {% endcomment %}

                {%- assign skip_card_product_styles = true -%}
              {%- endfor -%}
            </ul>

            {%- if paginate.pages > 1 -%}
              {% render 'pagination', paginate: paginate, anchor: '' %}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "t:sections.main-collection-product-grid.name",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16,
      "label": "t:sections.main-collection-product-grid.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "t:sections.main-collection-product-grid.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.main-collection-product-grid.settings.columns_mobile.label",
      "options": [
        { "value": "1", "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__1.label" },
        { "value": "2", "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__2.label" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__3.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__1.label" },
        { "value": "portrait", "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__2.label" },
        { "value": "square", "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__3.label" }
      ],
      "default": "adapt",
      "label": "t:sections.main-collection-product-grid.settings.image_ratio.label"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.show_secondary_image.label"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.show_rating.label"
    },
    {
      "type": "select",
      "id": "quick_add",
      "default": "none",
