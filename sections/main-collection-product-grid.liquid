{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
  {%- paginate collection.products by section.settings.products_per_page -%}
    
    {% comment %} --- FILTER & SORT COMPLETELY HIDDEN --- {% endcomment %}
    <style>
      .facets-wrapper, .facet-filters, .mobile-facets__wrapper, facet-filters-form {
        display: none !important;
      }
      .facets-vertical {
        display: block !important;
      }
      .facets-vertical .product-grid-container {
        width: 100% !important;
      }
    </style>

    <div class="{% if section.settings.filter_type == 'vertical' %} facets-vertical page-width{% endif %}">
      {{ 'component-facets.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>

      <div class="product-grid-container" id="ProductGridContainer">
        {%- if collection.products.size == 0 -%}
          <div class="collection collection--empty page-width" id="product-grid" data-id="{{ section.id }}">
            <div class="loading-overlay gradient"></div>
            <div class="title-wrapper center">
              <h2 class="title title--primary">
                {{ 'sections.collection_template.empty' | t -}}<br>
                {{ 'sections.collection_template.use_fewer_filters_html' | t: link: collection.url, class: 'underlined-link link' }}
              </h2>
            </div>
          </div>
        {%- else -%}
          <div class="collection{% if section.settings.filter_type != 'vertical' %} page-width{% endif %} pc-reveal">
            <div class="loading-overlay gradient"></div>
            <style>
              /* --- FIX FOR INVISIBLE PRODUCTS ON LOAD --- */
              #ProductGridContainer, 
              #ProductGridContainer .scroll-trigger,
              #ProductGridContainer .grid__item,
              .pc-reveal {
                opacity: 1 !important;
                transform: none !important;
                animation: none !important;
                visibility: visible !important;
              }

              /* --- PREMIUM SCROLL ANIMATION --- */
              .custom-fade-in-up {
                opacity: 0;
                transform: translateY(30px);
                transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
                will-change: opacity, transform;
              }
              .custom-fade-in-up.is-visible {
                opacity: 1;
                transform: translateY(0);
              }
              @media (prefers-reduced-motion: reduce) {
                .custom-fade-in-up {
                  opacity: 1 !important;
                  transform: none !important;
                  transition: none !important;
                }
              }

              /* --- RESPONSIVE GRID STRUCTURE --- */
              .fit-premium-grid {
                display: grid !important;
                gap: 8px !important; /* Smaller gap for mobile */
                padding: 0 !important;
                margin: 0 !important;
                width: 100% !important;
              }
              .fit-premium-grid .grid__item {
                width: 100% !important;
                max-width: 100% !important;
                padding: 0 !important;
                margin: 0 !important;
              }

              /* Allow Shopify setting to control mobile columns correctly */
              @media screen and (max-width: 749px) {
                .grid--1-col-tablet-down.fit-premium-grid {
                  grid-template-columns: 1fr !important;
                }
                .grid--2-col-tablet-down.fit-premium-grid {
                  grid-template-columns: repeat(2, 1fr) !important;
                }
              }

              /* Removing Default Card Borders & Padding */
              .fit-premium-grid .card-wrapper {
                height: auto !important;
                display: block !important;
                margin: 0 !important;
                padding: 0 !important;
                background: transparent !important;
                border: none !important;
              }
              .fit-premium-grid .card {
                background: transparent !important;
                border: none !important;
                margin: 0 !important;
                padding: 0 !important;
                box-shadow: none !important;
              }
              .fit-premium-grid .card__inner {
                border-radius: 12px !important;
                background-color: #f4f4f4 !important; 
                --ratio-percent: 125% !important;
                margin: 0 !important;
                padding: 0 !important;
                width: 100% !important;
                border: none !important;
              }
              .fit-premium-grid .card__inner::before {
                padding-bottom: 125% !important;
              }
              .fit-premium-grid .card__media {
                margin: 0 !important;
                padding: 0 !important;
                width: 100% !important;
                height: 100% !important;
              }
              
              /* Luxury Image Zoom Effect */
              .fit-premium-grid .media img, .slider-item-img-wrapper img {
                object-fit: cover !important;
                object-position: center top !important;
                width: 100% !important;
                height: 100% !important;
                margin: 0 !important;
                padding: 0 !important;
                transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) !important;
              }
              .fit-premium-grid .card-wrapper:hover .media img, .slider-item:hover .slider-item-img-wrapper img {
                transform: scale(1.06) !important;
              }

              /* --- PERFECT LEFT ALIGNMENT & CREATIVE TYPOGRAPHY (FLUID SCALING) --- */
              .fit-premium-grid .card-wrapper .card__content {
                padding: 10px 0 0 0 !important; /* Zero side padding to perfectly align with image edge */
                text-align: left !important; 
                display: flex !important;
                flex-direction: column !important;
                align-items: flex-start !important;
              }
              .fit-premium-grid .card-wrapper .card-information {
                text-align: left !important;
                align-items: flex-start !important;
                justify-content: flex-start !important;
                width: 100% !important;
              }
              
              /* Product Title */
              .fit-premium-grid .card-wrapper .card__heading {
                text-align: left !important;
                font-size: min(1.4rem, 3.8vw) !important; /* Scales down on mobile */
                font-weight: 600 !important;
                color: #111 !important;
                margin-bottom: 6px !important;
                line-height: 1.3 !important;
                letter-spacing: 0.3px !important;
                display: -webkit-box !important;
                -webkit-line-clamp: 2 !important;
                -webkit-box-orient: vertical !important;
                overflow: hidden !important;
                width: 100% !important;
                word-break: break-word !important; /* Prevents overflow */
              }
              
              /* Creative Price Row */
              .fit-premium-grid .card-wrapper .price, 
              .fit-premium-grid .card-wrapper .price__container,
              .fit-premium-grid .card-wrapper .price__sale {
                display: flex !important;
                justify-content: flex-start !important;
                align-items: center !important;
                text-align: left !important;
                flex-wrap: wrap !important;
                gap: 6px !important;
                width: 100% !important;
                margin: 0 !important;
              }
              
              /* Bold Sale Price */
              .fit-premium-grid .card-wrapper .price-item {
                font-size: min(1.6rem, 4.2vw) !important; /* Scales down on mobile */
                font-weight: 800 !important;
                color: #111 !important;
                margin: 0 !important;
                line-height: 1 !important;
              }
              
              /* Subtle Compare Price */
              .fit-premium-grid .card-wrapper .price__sale s.price-item--regular, 
              .fit-premium-grid .card-wrapper .price s,
              .fit-premium-grid .card-wrapper .price-item--regular {
                font-size: min(1.2rem, 3.2vw) !important;
                color: #888 !important;
                font-weight: 500 !important;
                text-decoration: line-through !important;
                line-height: 1 !important;
              }

              .fit-premium-grid .card-wrapper .card__badge {
                display: none !important; 
              }

              /* Premium Green Discount Pill */
              .fit-premium-grid .card-wrapper .price .badge,
              .fit-premium-grid .card-wrapper .price__badge-sale,
              .fit-premium-grid .card-wrapper .price-item--sale + span,
              .fit-premium-grid .card-wrapper .price__sale span:last-child {
                background-color: #e6f6ec !important; 
                color: #1b8a44 !important; 
                border: 1px solid rgba(27, 138, 68, 0.15) !important;
                font-size: min(1.05rem, 2.8vw) !important;
                font-weight: 800 !important;
                padding: 3px 6px !important;
                border-radius: 4px !important;
                text-transform: uppercase !important;
                letter-spacing: 0.5px !important;
                line-height: 1 !important;
                display: inline-flex !important;
                align-items: center !important;
                margin: 0 !important;
              }


              /* --- INLINE SLIDER CSS --- */
              .collection-slider-full-width {
                grid-column: 1 / -1 !important; 
                width: 100% !important;
                margin: 16px 0 24px 0 !important;
                overflow: hidden;
              }

              .offer-carousel-wrapper {
                display: flex;
                overflow-x: auto;
                gap: 8px;
                scroll-snap-type: x mandatory;
                scrollbar-width: none; 
                -ms-overflow-style: none; 
                margin-bottom: 16px;
                padding-bottom: 4px;
              }
              .offer-carousel-wrapper::-webkit-scrollbar { display: none; }
              
              .lucrative-offer-box {
                flex: 0 0 92%; 
                scroll-snap-align: center;
                border-radius: 12px;
                padding: 16px 20px; 
                display: flex;
                align-items: center;
                justify-content: space-between;
                box-shadow: 0 4px 15px rgba(0,0,0,0.05);
                position: relative;
                overflow: hidden;
                border: 1px solid rgba(255,255,255,0.1);
              }
              @media screen and (min-width: 750px) {
                .lucrative-offer-box { flex: 0 0 100%; }
              }
              .lucrative-offer-box::before {
                content: '';
                position: absolute;
                top: 0; left: -100%;
                width: 50%; height: 100%;
                background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0) 100%);
                transform: skewX(-20deg);
                animation: luxury-shine 6s infinite;
              }
              @keyframes luxury-shine {
                0% { left: -100%; }
                20% { left: 200%; }
                100% { left: 200%; }
              }
              .lucrative-offer-content {
                z-index: 2;
                display: flex;
                flex-direction: column;
                justify-content: center;
              }
              .lucrative-offer-heading {
                font-size: 1.8rem;
                font-weight: 800;
                margin: 0 0 2px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                line-height: 1.1;
              }
              .lucrative-offer-sub {
                font-size: 1.3rem;
                font-weight: 400;
                margin: 0;
                opacity: 0.9;
              }
              .lucrative-offer-coupon {
                z-index: 2;
                background: rgba(0,0,0,0.25);
                border: 1px dashed rgba(255,255,255,0.4);
                padding: 6px 12px;
                border-radius: 4px;
                font-weight: 700;
                font-size: 1.2rem;
                letter-spacing: 1px;
                backdrop-filter: blur(8px);
                text-transform: uppercase;
                white-space: nowrap;
              }

              /* Custom Slider Products */
              .custom-inline-slider {
                display: flex;
                overflow-x: auto;
                gap: 12px;
                scroll-snap-type: x mandatory;
                scrollbar-width: none; 
                -ms-overflow-style: none; 
                padding-bottom: 10px;
              }
              .custom-inline-slider::-webkit-scrollbar { display: none; }
              .custom-inline-slider .slider-item {
                flex: 0 0 75vw; /* Wider on mobile to fit nicely */
                max-width: 300px;
                scroll-snap-align: start;
                border-radius: 12px;
                overflow: hidden;
              }
              .slider-item-img-wrapper {
                border-radius: 12px;
                overflow: hidden;
                background: #f4f4f4;
                aspect-ratio: 4/5; 
              }
              
              /* Fluid Slider Typgraphy */
              .slider-item-details {
                padding: 12px 0 0 0;
                text-align: left; 
                display: flex;
                flex-direction: column;
              }
              .slider-item-rating {
                font-size: 1.1rem;
                color: #888;
                display: flex;
                align-items: center;
                justify-content: flex-start;
                gap: 4px;
                font-weight: 500;
                margin-bottom: 6px;
              }
              .stars-wrapper {
                display: flex;
                gap: 2px;
              }
              .stars-wrapper svg {
                width: 11px;
                height: 11px;
                fill: #FFD700;
              }
              .slider-item-title {
                font-size: min(var(--title-size, 1.4rem), 3.8vw) !important;
                font-weight: 600;
                margin-bottom: 6px;
                line-height: 1.3;
                color: #111;
                letter-spacing: 0.3px;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
                white-space: normal;
                word-break: break-word;
              }
              .slider-item-price-row {
                display: flex;
                align-items: center;
                justify-content: flex-start; 
                flex-wrap: wrap;
                gap: 6px;
                margin: 0;
              }
              .slider-item-price {
                font-weight: 800; 
                font-size: min(var(--price-size, 1.6rem), 4.2vw) !important;
                color: #111;
                line-height: 1;
              }
              .slider-item-compare {
                text-decoration: line-through;
                font-size: calc(min(var(--price-size, 1.6rem), 4.2vw) * 0.75) !important;
                color: #888;
                font-weight: 500;
                line-height: 1;
              }
              .slider-item-discount {
                font-size: min(var(--discount-size, 1.1rem), 2.8vw) !important;
                font-weight: 800;
                color: #1b8a44; 
                background: #e6f6ec; 
                border: 1px solid rgba(27, 138, 68, 0.15);
                padding: 3px 6px;
                border-radius: 4px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                line-height: 1;
              }

              .dummy-placeholder {
                background: #f4f4f4;
                padding: 40px 20px;
                text-align: center;
                border: 2px dashed #ccc;
                width: 100%;
                max-width: 100% !important;
                flex: 0 0 100% !important;
              }

              /* --- SPECIFIC MOBILE FIXES --- */
              @media (max-width: 749px) {
                .lucrative-offer-box {
                  flex-direction: column !important;
                  align-items: flex-start !important;
                  padding: 16px !important;
                  gap: 12px;
                  min-height: auto !important; /* Disables manual height forcing on mobile */
                }
                .lucrative-offer-heading { font-size: 1.5rem !important; }
                .lucrative-offer-sub { font-size: 1.1rem !important; }
                .lucrative-offer-coupon { font-size: 1.0rem !important; padding: 4px 8px !important; }
              }

              @media screen and (min-width: 750px) {
                .fit-premium-grid {
                  grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr) !important;
                  gap: 24px !important; /* Larger gap on desktop */
                }
                .custom-inline-slider .slider-item {
                  flex: 0 0 25vw; 
                }
              }
            </style>
            
            <ul
              id="product-grid"
              data-id="{{ section.id }}"
              class="grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop fit-premium-grid"
            >
              {% assign skip_card_product_styles = false %}
              {%- for product in collection.products -%}
                {% assign lazy_load = false %}
                {%- if forloop.index > 2 -%}{%- assign lazy_load = true -%}{%- endif -%}
                {% assign current_product_index = forloop.index %}

                <li class="grid__item custom-fade-in-up">
                  {% render 'card-product',
                    card_product: product,
                    media_aspect_ratio: section.settings.image_ratio,
                    image_shape: section.settings.image_shape,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    lazy_load: lazy_load,
                    skip_styles: skip_card_product_styles,
                    quick_add: section.settings.quick_add,
                    section_id: section.id
                  %}
                </li>

                {% comment %} --- INLINE SLIDER INJECTION (DYNAMIC BY CAMPAIGN BLOCKS) --- {% endcomment %}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'slider_campaign' and block.settings.insert_after == current_product_index -%}
                    
                    {%- assign show_campaign = true -%}
                    {%- if block.settings.target_collection != blank and block.settings.target_collection.handle != collection.handle -%}
                      {%- assign show_campaign = false -%}
                    {%- endif -%}

                    {%- if show_campaign -%}
                      <li class="grid__item collection-slider-full-width custom-fade-in-up" {{ block.shopify_attributes }}>
                        
                        {% comment %} Offer Banner Carousel (Supports up to 3 slides) {% endcomment %}
                        <div class="offer-carousel-wrapper">
                          
                          {%- if block.settings.heading_1 != blank -%}
                          <div class="lucrative-offer-box" style="background: linear-gradient(135deg, {{ block.settings.bg_color_1 }}, {{ block.settings.bg_color_2 }}); color: {{ block.settings.text_color }}; min-height: {{ block.settings.offer_box_height }}px;">
                            <div class="lucrative-offer-content">
                              <h3 class="lucrative-offer-heading" style="color: {{ block.settings.text_color }};">{{ block.settings.heading_1 }}</h3>
                              <p class="lucrative-offer-sub" style="color: {{ block.settings.text_color }};">{{ block.settings.subheading_1 }}</p>
                            </div>
                            {%- if block.settings.coupon_code_1 != blank -%}
                              <div class="lucrative-offer-coupon" style="color: {{ block.settings.text_color }};">Code: <span>{{ block.settings.coupon_code_1 }}</span></div>
                            {%- endif -%}
                          </div>
                          {%- endif -%}

                          {%- if block.settings.heading_2 != blank -%}
                          <div class="lucrative-offer-box" style="background: linear-gradient(135deg, {{ block.settings.bg_color_1 }}, {{ block.settings.bg_color_2 }}); color: {{ block.settings.text_color }}; min-height: {{ block.settings.offer_box_height }}px;">
                            <div class="lucrative-offer-content">
                              <h3 class="lucrative-offer-heading" style="color: {{ block.settings.text_color }};">{{ block.settings.heading_2 }}</h3>
                              <p class="lucrative-offer-sub" style="color: {{ block.settings.text_color }};">{{ block.settings.subheading_2 }}</p>
                            </div>
                            {%- if block.settings.coupon_code_2 != blank -%}
                              <div class="lucrative-offer-coupon" style="color: {{ block.settings.text_color }};">Code: <span>{{ block.settings.coupon_code_2 }}</span></div>
                            {%- endif -%}
                          </div>
                          {%- endif -%}

                          {%- if block.settings.heading_3 != blank -%}
                          <div class="lucrative-offer-box" style="background: linear-gradient(135deg, {{ block.settings.bg_color_1 }}, {{ block.settings.bg_color_2 }}); color: {{ block.settings.text_color }}; min-height: {{ block.settings.offer_box_height }}px;">
                            <div class="lucrative-offer-content">
                              <h3 class="lucrative-offer-heading" style="color: {{ block.settings.text_color }};">{{ block.settings.heading_3 }}</h3>
                              <p class="lucrative-offer-sub" style="color: {{ block.settings.text_color }};">{{ block.settings.subheading_3 }}</p>
                            </div>
                            {%- if block.settings.coupon_code_3 != blank -%}
                              <div class="lucrative-offer-coupon" style="color: {{ block.settings.text_color }};">Code: <span>{{ block.settings.coupon_code_3 }}</span></div>
                            {%- endif -%}
                          </div>
                          {%- endif -%}

                        </div>

                        {% comment %} Matched Product Slider Items {% endcomment %}
                        <div class="custom-inline-slider" style="--title-size: {{ block.settings.font_size_title }}rem; --price-size: {{ block.settings.font_size_price }}rem; --discount-size: {{ block.settings.font_size_discount }}rem;">
                          {% assign has_items = false %}
                          {% assign target_campaign_id = block.settings.campaign_id %}
                          
                          {%- for item in section.blocks -%}
                            {%- if item.type == 'slider_item' and item.settings.campaign_id == target_campaign_id -%}
                              
                              {%- assign show_item = true -%}
                              {%- if item.settings.target_collection != blank and item.settings.target_collection.handle != collection.handle -%}
                                {%- assign show_item = false -%}
                              {%- endif -%}

                              {%- if show_item -%}
                                {% assign has_items = true %}
                                
                                <div class="slider-item" {{ item.shopify_attributes }}>
                                  <a href="{{ item.settings.link | default: '#' }}" style="text-decoration: none; color: inherit;">
                                    
                                    <div class="slider-item-img-wrapper">
                                      {%- if item.settings.image != blank -%}
                                        {{ item.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                                      {%- else -%}
                                        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                      {%- endif -%}
                                    </div>
                                    
                                    <div class="slider-item-details">
                                      {% comment %} 1. Rating {% endcomment %}
                                      {%- if item.settings.rating != blank -%}
                                        <div class="slider-item-rating">
                                          <div class="stars-wrapper">
                                            <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                            <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                            <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                            <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                            <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                          </div>
                                          <span>({{ item.settings.rating }})</span>
                                        </div>
                                      {%- endif -%}

                                      {% comment %} 2. Title {% endcomment %}
                                      {%- if item.settings.title != blank -%}
                                        <div class="slider-item-title">{{ item.settings.title }}</div>
                                      {%- endif -%}
                                      
                                      {% comment %} 3. Price & Green Discount {% endcomment %}
                                      <div class="slider-item-price-row">
                                        {%- if item.settings.price != blank -%}
                                          <span class="slider-item-price">{{ item.settings.price }}</span>
                                        {%- endif -%}
                                        {%- if item.settings.compare_price != blank -%}
                                          <span class="slider-item-compare">{{ item.settings.compare_price }}</span>
                                        {%- endif -%}
                                        {%- if item.settings.discount != blank -%}
                                          <span class="slider-item-discount">{{ item.settings.discount }}</span>
                                        {%- endif -%}
                                      </div>
                                    </div>

                                  </a>
                                </div>
                              {%- endif -%}

                            {%- endif -%}
                          {%- endfor -%}

                          {%- if has_items == false -%}
                            <div class="slider-item dummy-placeholder">
                               <h3 style="margin:0; font-size: 16px;">Banner Ready! ✅</h3>
                               <p style="margin: 5px 0 0; font-size: 14px;">Add <strong>Slider Image Items</strong> in the Theme Editor and set their Campaign ID to: <strong>{{ target_campaign_id }}</strong></p>
                            </div>
                          {%- endif -%}
                        </div>

                      </li>
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
                {% comment %} --- END INLINE SLIDER --- {% endcomment %}

                {%- assign skip_card_product_styles = true -%}
              {%- endfor -%}
            </ul>

            {%- if paginate.pages > 1 -%}
              {% render 'pagination', paginate: paginate, anchor: '' %}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}

  {% comment %} --- CUSTOM SCROLL ANIMATION SCRIPT --- {% endcomment %}
  <script>
    (function() {
      function initCustomReveal() {
        const observer = new IntersectionObserver((entries, obs) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              obs.unobserve(entry.target);
            }
          });
        }, {
          threshold: 0.05,
          rootMargin: "0px 0px 50px 0px"
        });

        const elements = document.querySelectorAll('.custom-fade-in-up:not(.is-visible)');
        elements.forEach(el => observer.observe(el));
      }

      initCustomReveal();

      document.addEventListener('shopify:section:load', initCustomReveal);
      
      const gridContainer = document.getElementById('ProductGridContainer');
      if (gridContainer) {
        const mutationObserver = new MutationObserver(() => {
          initCustomReveal();
        });
        mutationObserver.observe(gridContainer, { childList: true, subtree: true });
      }
    })();
  </script>
</div>

