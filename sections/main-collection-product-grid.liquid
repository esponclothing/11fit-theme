                              {%- endif -%}
                            </div>
                            {%- endif -%}

                            {%- if camp.heading_2 != blank -%}
                            <div class="lucrative-offer-box" style="background: linear-gradient(135deg, {{ camp.bg_color_1 | default: '#111111' }}, {{ camp.bg_color_2 | default: '#2b2b2b' }}); color: {{ camp.text_color | default: '#ffffff' }}; min-height: {{ camp.offer_box_height | default: 70 }}px;">
                              <div class="lucrative-offer-content">
                                <h3 class="lucrative-offer-heading" style="color: {{ camp.text_color | default: '#ffffff' }};">{{ camp.heading_2 }}</h3>
                                <p class="lucrative-offer-sub" style="color: {{ camp.text_color | default: '#ffffff' }};">{{ camp.subheading_2 }}</p>
                              </div>
                              {%- if camp.coupon_code_2 != blank -%}
