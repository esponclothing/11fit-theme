                              <div class="lucrative-offer-content">
                                <h3 class="lucrative-offer-heading" style="color: {{ camp.text_color | default: '#ffffff' }};">{{ camp.heading_1 }}</h3>
                                <p class="lucrative-offer-sub" style="color: {{ camp.text_color | default: '#ffffff' }};">{{ camp.subheading_1 }}</p>
                              </div>
                              {%- if camp.coupon_code_1 != blank -%}
