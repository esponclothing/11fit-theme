                              {%- endif -%}
                            </div>
                            {%- endif -%}

                            {%- if camp.heading_3 != blank -%}
                            <div class="lucrative-offer-box" style="background: linear-gradient(135deg, {{ camp.bg_color_1 | default: '#111111' }}, {{ camp.bg_color_2 | default: '#2b2b2b' }}); color: {{ camp.text_color | default: '#ffffff' }}; min-height: {{ camp.offer_box_height | default: 70 }}px;">
                              <div class="lucrative-offer-content">
                                <h3 class="lucrative-offer-heading" style="color: {{ camp.text_color | default: '#ffffff' }};">{{ camp.heading_3 }}</h3>
                                <p class="lucrative-offer-sub" style="color: {{ camp.text_color | default: '#ffffff' }};">{{ camp.subheading_3 }}</p>
                              </div>
                              {%- if camp.coupon_code_3 != blank -%}
                                <div class="lucrative-offer-coupon" style="color: {{ camp.text_color | default: '#ffffff' }}; cursor: pointer;" onclick="copyCouponCode(this, '{{ camp.coupon_code_3 }}');">Code: <span>{{ camp.coupon_code_3 }}</span></div>
                              {%- endif -%}
                            </div>
                            {%- endif -%}
                          </div>

                          <div class="custom-inline-slider" style="--title-size: 1.3rem; --price-size: 1.5rem; --discount-size: 1.1rem;">
                            {%- assign has_items = false -%}
                            {%- for item in camp.items -%}
                              {%- assign has_items = true -%}
                              <div class="slider-item">
                                <a href="{{ item.link | default: '#' }}" style="text-decoration: none; color: inherit; display: flex; flex-direction: column; height: 100%;">
                                  <div class="slider-item-img-wrapper">
                                    {%- if item.image != blank -%}
                                      <img src="{{ item.image }}" loading="lazy" />
                                    {%- else -%}
                                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                    {%- endif -%}
                                    {%- if item.rating != blank -%}
                                      <div class="slider-rating-badge">
                                        <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                        {{ item.rating }}
                                      </div>
                                    {%- endif -%}
                                  </div>
                                  <div class="slider-item-details">
                                    {%- if item.title != blank -%}
                                      <div class="slider-item-title">{{ item.title }}</div>
                                    {%- endif -%}
                                    <div class="slider-item-price-row">
                                      {%- if item.price != blank -%}
                                        <span class="slider-item-price">{{ item.price }}</span>
                                      {%- endif -%}
                                      {%- if item.compare_price != blank -%}
