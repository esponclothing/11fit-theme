                                      {%- endif -%}
                                      {%- if item.discount != blank -%}
                                        <span class="slider-item-discount">{{ item.discount }}</span>
                                      {%- endif -%}
                                    </div>
                                    <div class="lowest-price-text">Lowest price in last 30 days</div>
                                  </div>
                                </a>
                              </div>
                            {%- endfor -%}
