<div class="fit11-modal-overlay" id="fit11OffersModal" onclick="if(event.target === this) fit11ToggleOffersModal(false);">
  <div class="fit11-modal-content">
    <button type="button" class="fit11-modal-close" onclick="fit11ToggleOffersModal(false);"><i class="ti ti-x"></i></button>
    <h3 style="font-family: var(--font-heading); font-size: 24px; font-weight: 400; margin: 0 0 20px 0; border-bottom: 1px solid var(--lux-border); padding-bottom: 12px;">All Offers & Discounts</h3>
    <div class="fit11-modal-body" style="display: flex; flex-direction: column; gap: 16px;">
      {% if combo_active %}
        {% assign m_combo_price = product.metafields.price_editor.combo_config.value.comboPrice %}
        {% assign m_price_per_item = m_combo_price | divided_by: combo_count %}
        {% assign m_regular_total = product.price | times: combo_count | divided_by: 100.0 %}
        {% assign m_total_saved = m_regular_total | minus: m_combo_price %}
        <div class="fit11-offer-card" style="width: 100%; min-width: 100%; scroll-snap-align: none; border-color: #ffdf00; cursor: default; flex-direction: column; padding: 16px;" onclick="fit11ToggleOffersModal(false); document.querySelector('.combo-size-select').focus();">
          <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
            <div class="fit11-offer-code" style="font-size: 14px; font-weight: 600; color: #1a202c;">{{ combo_count }} COMBO OFFER</div>
            <div style="background: #198754; color: #fff; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 700; text-transform: uppercase;">Deal Applied</div>
          </div>
          <div class="fit11-offer-desc" style="font-size: 13px; color: #1a202c; font-weight: 500; margin-top: 4px;">
            {{ combo_count }} {{ product.title | escape }} at <span style="color: #198754; font-weight: 700;">Rs.{{ m_price_per_item | round }} Each</span>
          </div>
          <div class="fit11-offer-desc" style="font-weight: 600; color: #d9480f; margin-top: 6px; font-size: 13px;">
            <i class="ti ti-flame"></i> You Saved ₹{{ m_total_saved | round }} Instantly!
          </div>
          <div style="border-top: 1px dashed #cbd5e0; margin-top: 12px; padding-top: 10px; display: flex; justify-content: space-between; font-size: 11px; font-weight: 500; color: #718096;">
            <span style="color: #198754; display: flex; align-items: center; gap: 4px;"><i class="ti ti-truck"></i> Free Delivery</span>
            <span>No Coupon Needed</span>
          </div>
        </div>
      {% endif %}
      {% if active_campaign != blank %}
        {% render 'campaign-banner', inline_card: true %}
      {% endif %}
      {% for block in offer_blocks %}
        <div class="fit11-offer-card" onclick="fit11CopyCoupon(this, '{{ block.settings.offer_code }}')" style="width: 100%; min-width: 100%; scroll-snap-align: none;">
          <div class="fit11-offer-content-wrap">
            <div class="fit11-offer-code">{{ block.settings.offer_code }}</div>
            <div class="fit11-offer-desc">{{ block.settings.offer_desc }}</div>
            {% if block.settings.offer_code != blank %}
              <div class="fit11-copy-hint"><i class="ti ti-copy"></i> Click to Copy</div>
            {% endif %}
          </div>
          {% if block.settings.offer_timer != blank %}
            <div class="fit11-offer-timer">{{ block.settings.offer_timer }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

{% comment %} ── SIZE CHART MODAL ── {% endcomment %}
<div class="fit11-modal-overlay" id="fit11SizeModal" onclick="if(event.target === this) fit11ToggleModal(false);">
  <div class="fit11-modal-content">
    <button type="button" class="fit11-modal-close" onclick="fit11ToggleModal(false);"><i class="ti ti-x"></i></button>
    <h3 style="font-family: var(--font-heading); font-size: 24px; font-weight: 400; margin: 0 0 20px 0; border-bottom: 1px solid var(--lux-border); padding-bottom: 12px;">Size Guide</h3>
    <div class="fit11-modal-body">
        <style>
          .fit11-size-tabs { display: flex; gap: 8px; margin-bottom: 16px; border-bottom: 1px solid var(--lux-border); }
          .fit11-size-tab { padding: 8px 16px; cursor: pointer; font-size: 13px; font-weight: 500; color: var(--lux-text-muted); border-bottom: 2px solid transparent; }
          .fit11-size-tab.active { color: var(--lux-text); border-bottom: 2px solid var(--lux-text); }
          .fit11-size-pane { display: none; overflow-x: auto; width: 100%; }
          .fit11-size-pane.active { display: block; }
          .fit11-size-table { width: 100%; border-collapse: collapse; text-align: left; }
          .fit11-size-table th, .fit11-size-table td { padding: 12px 16px; border-bottom: 1px solid var(--lux-border); color: var(--lux-text); font-size: 13px; white-space: nowrap; }
          .fit11-size-table th { font-weight: 600; color: var(--lux-text-muted); font-size: 12px; }
          .fit11-size-table tbody tr:last-child td { border-bottom: none; }
        </style>

        <div class="fit11-size-tabs">
          <div class="fit11-size-tab active" onclick="fit11SwitchSizeTab(this, 'tshirt')">T-Shirt</div>
          <div class="fit11-size-tab" onclick="fit11SwitchSizeTab(this, 'trackpants')">Track Pants</div>
          <div class="fit11-size-tab" onclick="fit11SwitchSizeTab(this, 'shorts')">Shorts</div>
        </div>

        <div id="size-pane-tshirt" class="fit11-size-pane active">
          <table class="fit11-size-table">
            <thead>
              <tr style="border-bottom: 2px solid var(--lux-border); font-weight:500;"><th>Size</th><th>Chest (in)</th><th>Length (in)</th></tr>
            </thead>
            <tbody>
              <tr><td>XS</td><td>36</td><td>25</td></tr>
              <tr><td>S</td><td>38</td><td>26</td></tr>
              <tr><td>M</td><td>40</td><td>27</td></tr>
              <tr><td>L</td><td>42</td><td>28</td></tr>
              <tr><td>XL</td><td>44</td><td>29</td></tr>
              <tr><td>2XL</td><td>46</td><td>30</td></tr>
              <tr><td>3XL</td><td>48</td><td>31</td></tr>
              <tr><td>4XL</td><td>50</td><td>32</td></tr>
              <tr><td>5XL</td><td>52</td><td>32</td></tr>
              <tr><td>6XL</td><td>56</td><td>33</td></tr>
              <tr><td>7XL</td><td>60</td><td>33</td></tr>
            </tbody>
          </table>
        </div>

        <div id="size-pane-trackpants" class="fit11-size-pane">
          <table class="fit11-size-table">
            <thead>
              <tr style="border-bottom: 2px solid var(--lux-border); font-weight:500;"><th>Size</th><th>Waist (in)</th><th>Length (in)</th></tr>
            </thead>
            <tbody>
              <tr><td>S</td><td>28 - 30</td><td>38</td></tr>
              <tr><td>M</td><td>30 - 32</td><td>39</td></tr>
              <tr><td>L</td><td>32 - 34</td><td>40</td></tr>
              <tr><td>XL</td><td>34 - 36</td><td>41</td></tr>
              <tr><td>2XL</td><td>36 - 38</td><td>42</td></tr>
            </tbody>
          </table>
        </div>

        <div id="size-pane-shorts" class="fit11-size-pane">
          <table class="fit11-size-table">
            <thead>
              <tr style="border-bottom: 2px solid var(--lux-border); font-weight:500;">
                <th>Size</th>
                <th>Waist (in)</th>
                <th>Inseam (in)</th>
                <th>Hip (in)</th>
                <th>Outseam (in)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>S</td><td>28-30</td><td>8.5</td><td>38</td><td>16</td></tr>
              <tr><td>M</td><td>30-32</td><td>8.5</td><td>40</td><td>17</td></tr>
              <tr><td>L</td><td>32-34</td><td>8.5</td><td>42</td><td>18</td></tr>
              <tr><td>XL</td><td>34-36</td><td>8.5</td><td>44</td><td>19</td></tr>
              <tr><td>XXL</td><td>36-38</td><td>8.5</td><td>46</td><td>20</td></tr>
              <tr><td>XXXL</td><td>38-40</td><td>8.5</td><td>48</td><td>21</td></tr>
            </tbody>
          </table>
        </div>

        <script>
          function fit11SwitchSizeTab(tabElem, paneId) {
            var tabs = tabElem.parentElement.querySelectorAll('.fit11-size-tab');
            tabs.forEach(function(t) { t.classList.remove('active'); });
            tabElem.classList.add('active');

            var panes = tabElem.parentElement.parentElement.querySelectorAll('.fit11-size-pane');
            panes.forEach(function(p) { p.classList.remove('active'); });
            var targetPane = tabElem.parentElement.parentElement.querySelector('#size-pane-' + paneId);
            if (targetPane) targetPane.classList.add('active');
          }
        </script>
    </div>
  </div>
</div>



<script>
(function() {
  function initGallery() {
    var sectionContainer = document.getElementById('fit11-page-{{ section.id }}') || document;
    var slides = sectionContainer.querySelector('.fit11-slides');
    var dotsWrap = sectionContainer.querySelector('.fit11-ext-dots');
    var thumbsWrap = sectionContainer.querySelector('.fit11-thumbs');

    if (!slides) return;

    var slideElements = slides.querySelectorAll('.fit11-slide');
    var dots = dotsWrap ? dotsWrap.querySelectorAll('.fit11-ext-dot') : [];
    var thumbs = thumbsWrap ? thumbsWrap.querySelectorAll('.fit11-thumb') : [];
    var total = slideElements.length;
    var cur = 0;
    var autoSlideInterval = null;
    var isUserInteracting = false;
    var resumeTimeout = null;

    var autoSwipeSpeed = {{ section.settings.auto_swipe_speed | default: 3000 }};

    window.goToSlide = function(n) {
      if (total <= 0) return;
      if (n < 0) n = total - 1;
      if (n >= total) n = 0;

      if (dots[cur]) dots[cur].classList.remove('on');
      if (thumbs[cur]) thumbs[cur].classList.remove('on');

      cur = n;

      var slideWidth = slides.offsetWidth;
      if (slideWidth > 0) {
        // Temporarily disable scroll-snap so programmatic scroll works
        slides.style.scrollSnapType = 'none';
        slides.style.scrollBehavior = 'smooth';
        slides.scrollLeft = cur * slideWidth;
        // Re-enable snap after animation completes
        setTimeout(function() {
          slides.style.scrollSnapType = '';
          slides.style.scrollBehavior = '';
        }, 400);
      }

      if (dots[cur]) dots[cur].classList.add('on');
      if (thumbs[cur]) thumbs[cur].classList.add('on');
    };

    function goTo(n) { window.goToSlide(n); }

    if ('IntersectionObserver' in window && total > 0) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var idx = Array.prototype.indexOf.call(slideElements, entry.target);
            if (idx !== -1 && idx !== cur) {
              if (dots[cur]) dots[cur].classList.remove('on');
              if (thumbs[cur]) thumbs[cur].classList.remove('on');
              cur = idx;
              if (dots[cur]) dots[cur].classList.add('on');
              if (thumbs[cur]) thumbs[cur].classList.add('on');
            }
          }
        });
      }, {
        root: slides,
        threshold: 0.5 
      });

      slideElements.forEach(function(slide) {
        observer.observe(slide);
      });
    } else {
      var scrollTimeout;
      slides.addEventListener('scroll', function() {
        clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(function() {
          var slideWidth = slides.clientWidth || (slides.firstElementChild ? slides.firstElementChild.clientWidth : 0);
          if (slideWidth <= 0) return;
          var idx = Math.round(slides.scrollLeft / slideWidth);
          if (idx !== cur && idx >= 0 && idx < total) {
            if (dots[cur]) dots[cur].classList.remove('on');
            if (thumbs[cur]) thumbs[cur].classList.remove('on');
            cur = idx;
            if (dots[cur]) dots[cur].classList.add('on');
            if (thumbs[cur]) thumbs[cur].classList.add('on');
          }
        }, 50);
      });
    }

    dots.forEach(function(d, i) {
      d.addEventListener('click', function() {
        resetAutoSwipe();
        goTo(i);
      });
    });

    thumbs.forEach(function(t, i) {
      t.addEventListener('click', function() {
        resetAutoSwipe();
        goTo(i);
      });
    });

    function startAutoSwipe() {
      if (autoSlideInterval) clearInterval(autoSlideInterval);
      if (total > 1) {
        autoSlideInterval = setInterval(function() {
          if (!isUserInteracting) {
            goTo((cur + 1) % total);
          }
        }, 1500); // 1.5s: gives 300ms for smooth scroll + 1.2s pause
      }
    }

    window.fit11StopAutoSwipe = function() {
      isUserInteracting = true;
      if (autoSlideInterval) clearInterval(autoSlideInterval);
      if (resumeTimeout) clearTimeout(resumeTimeout);
    };

    window.fit11ResetAutoSwipe = function(delay) {
      isUserInteracting = false;
      if (resumeTimeout) clearTimeout(resumeTimeout);
      resumeTimeout = setTimeout(function() {
        startAutoSwipe();
      }, delay || 2000); // resume after delay
    };

    function stopAutoSwipe() { window.fit11StopAutoSwipe(); }
    function resetAutoSwipe() { window.fit11ResetAutoSwipe(2000); }

    slides.addEventListener('touchstart', stopAutoSwipe, {passive: true});
    slides.addEventListener('touchend', resetAutoSwipe, {passive: true});
    slides.addEventListener('mousedown', stopAutoSwipe, {passive: true});
    slides.addEventListener('mouseup', resetAutoSwipe, {passive: true});

    startAutoSwipe();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGallery);
  } else {
    initGallery();
  }
})();

  /* LIGHTBOX LOGIC */
  document.querySelectorAll('.fit11-slide img').forEach(function(img) {
    img.style.cursor = 'zoom-in';
    img.addEventListener('click', function() {
      var lightbox = document.getElementById('fit11Lightbox');
      if(lightbox) {
        document.getElementById('fit11LightboxImg').src = this.src;
        lightbox.style.display = 'flex';
      }
    });
  });

  /* PREVENT ACCIDENTAL CLICK WHILE SWIPING PILLS */
  document.querySelectorAll('.fit11-variant-pills').forEach(function(container) {
    var isDragging = false;
    var startX = 0;
    var startY = 0;
    container.addEventListener('touchstart', function(e) {
      isDragging = false;
      if (e.touches && e.touches[0]) {
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
      }
    }, { passive: true });
    container.addEventListener('touchmove', function(e) {
      if (e.touches && e.touches[0]) {
        var diffX = Math.abs(e.touches[0].clientX - startX);
        if (diffX > 6) {
          isDragging = true;
        }
      }
    }, { passive: true });
    container.addEventListener('click', function(e) {
      if (isDragging) {
        e.preventDefault();
        e.stopPropagation();
      }
    }, true);
  });

  /* SIZE MODAL */
  window.fit11ToggleModal = function(show) {
    var modal = document.getElementById('fit11SizeModal');
    if(!modal) return;
    if(show) {
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    } else {
      modal.classList.remove('open');
      document.body.style.overflow = '';
    }
  };

  /* OFFERS MODAL */
  window.fit11ToggleOffersModal = function(show) {
    var modal = document.getElementById('fit11OffersModal');
    if(!modal) return;
    if(show) {
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    } else {
      modal.classList.remove('open');
      document.body.style.overflow = '';
    }
  };

  /* REAL-TIME COUNTDOWN LOGIC */
  document.querySelectorAll('.fit11-offer-timer').forEach(function(el) {
    var text = el.innerText;
    // Look for format like "Ends in 07h 06m 05s"
    var match = text.match(/(\d+)h\s*(\d+)m\s*(\d+)s/i);

    if(match) {
      var h = parseInt(match[1], 10);
      var m = parseInt(match[2], 10);
      var s = parseInt(match[3], 10);
      var totalSeconds = (h * 3600) + (m * 60) + s;
      var prefix = text.split(match[0])[0];

      var interval = setInterval(function() {
        totalSeconds--;
        if(totalSeconds <= 0) {
          clearInterval(interval);
          el.innerText = "Expired";
          var card = el.closest('.fit11-offer-card');
          if(card) {
            card.classList.add('expired');
            var hint = card.querySelector('.fit11-copy-hint');
            if(hint) hint.innerHTML = "Code Expired";
          }
        } else {
          var outH = Math.floor(totalSeconds / 3600);
          var outM = Math.floor((totalSeconds % 3600) / 60);
          var outS = totalSeconds % 60;
          el.innerText = prefix +
            (outH < 10 ? "0"+outH : outH) + "h " +
            (outM < 10 ? "0"+outM : outM) + "m " +
            (outS < 10 ? "0"+outS : outS) + "s";
        }
      }, 1000);
    }
  });

  /* ── VARIANT SELECTION LOGIC ── */
  var sectionContainer = document.getElementById('fit11-page-{{ section.id }}') || document;
  var variantRadios = sectionContainer.querySelectorAll('.fit11-variant-radio');
  var variantIdInput = sectionContainer.querySelector('#fit11-variant-id') || document.getElementById('fit11-variant-id');
  var variantsJsonEl = sectionContainer.querySelector('#ProductVariantsData') || document.getElementById('ProductVariantsData');

  if (variantsJsonEl) {
    var variantsData = JSON.parse(variantsJsonEl.textContent);

    function formatMoney(cents) {
      var val = (cents / 100).toFixed(0);
      var formatted = val.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
      return "Rs. " + formatted;
    }

    function updateSelectedVariant() {
      var selectedOptions = [];
      sectionContainer.querySelectorAll('.fit11-option-fieldset').forEach(function(fieldset) {
        var checkedRadio = fieldset.querySelector('.fit11-variant-radio:checked');
        if (checkedRadio) {
          var val = checkedRadio.value;
          if (selectedOptions.indexOf(val) === -1) {
            selectedOptions.push(val);
          }
          if (checkedRadio.getAttribute('data-is-color') === 'true') {
            sectionContainer.querySelectorAll('.fit11-selected-color-label').forEach(function(lbl) {
              lbl.innerText = val;
            });
          }
        }
      });

      var matchedVariant = variantsData.find(function(variant) {
        return selectedOptions.every(function(val) {
          return variant.options.indexOf(val) !== -1;
        });
      });

      if (matchedVariant && variantIdInput) {
        variantIdInput.value = matchedVariant.id;
        window.history.replaceState({}, '', '?variant=' + matchedVariant.id);

        var priceMain = sectionContainer.querySelector('.fit11-price-main');
        var priceOff = sectionContainer.querySelector('.fit11-price-off');
        var priceMrp = sectionContainer.querySelector('.fit11-price-mrp');
        var priceLowest = sectionContainer.querySelector('.fit11-price-lowest');
        var priceOld = sectionContainer.querySelector('.fit11-price-old');
        var stickyPrice = sectionContainer.querySelector('.fit11-sticky-text p');

        if (priceMain) priceMain.innerText = formatMoney(matchedVariant.price);
        if (stickyPrice) stickyPrice.innerText = formatMoney(matchedVariant.price);

        if (matchedVariant.compare_at_price > matchedVariant.price) {
          if (priceOff) {
            priceOff.innerText = formatMoney(matchedVariant.compare_at_price - matchedVariant.price) + ' OFF';
            priceOff.style.display = 'inline';
          }
          if (priceOld) priceOld.innerText = formatMoney(matchedVariant.compare_at_price);
          if (priceMrp) priceMrp.style.display = 'block';
          if (priceLowest) priceLowest.style.display = 'block';
        } else {
          if (priceOff) priceOff.style.display = 'none';
          if (priceMrp) priceMrp.style.display = 'none';
          if (priceLowest) priceLowest.style.display = 'none';
        }

        if (matchedVariant.featured_image && matchedVariant.featured_image.id) {
          var imageId = matchedVariant.featured_image.id;
          var targetSlide = document.querySelector('.fit11-slide[data-image-id="' + imageId + '"]');
          if (targetSlide) {
            var slideElements = Array.from(document.querySelectorAll('.fit11-slide'));
            var targetIndex = slideElements.indexOf(targetSlide);
            if (targetIndex !== -1 && typeof window.goToSlide === 'function') {
              window.goToSlide(targetIndex);
            }
          }
        }
      }
    }

    variantRadios.forEach(function(radio) {
      radio.addEventListener('change', function(e) {
        // Pause auto-swipe and give user 6 seconds to view the new variant image
        if (typeof window.fit11StopAutoSwipe === 'function') {
          window.fit11StopAutoSwipe();
          window.fit11ResetAutoSwipe(6000); 
        }

        if (radio.getAttribute('data-is-color') === 'true') {
          var val = radio.value;
          document.querySelectorAll('.fit11-variant-radio[data-is-color="true"]').forEach(function(r) {
            if (r.value === val && r !== radio) {
              r.checked = true;
            }
          });
        }
        updateSelectedVariant();
      });
    });
  }

  /* FASHION BAG FLY ANIMATION */
  function playBagAnimation(sourceButton) {
    if(!sourceButton) return;
    var btnRect = sourceButton.getBoundingClientRect();
    var cartIcon = document.querySelector('.header__icon--cart, #cart-icon-bubble, .cart-icon-wrapper, a[href="/cart"], .cart-count');
    var cartRect = cartIcon ? cartIcon.getBoundingClientRect() : { top: 20, left: window.innerWidth - 60, width: 40, height: 40 };

    var bagSize = 44;
    var bag = document.createElement('div');
    bag.className = 'fit11-fly-bag';
    bag.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6.331 8h11.339a2 2 0 0 1 1.977 2.304l-1.255 8.152a3 3 0 0 1 -2.966 2.544h-6.852a3 3 0 0 1 -2.965 -2.544l-1.255 -8.152a2 2 0 0 1 1.977 -2.304z"/><path d="M9 11v-5a3 3 0 0 1 6 0v5"/></svg>';

    var startX = btnRect.left + (btnRect.width / 2) - (bagSize / 2);
    var startY = btnRect.top + (btnRect.height / 2) - (bagSize / 2);

    bag.style.top = '0px'; bag.style.left = '0px';
    bag.style.width = bagSize + 'px'; bag.style.height = bagSize + 'px';
    bag.style.transform = 'translate(' + startX + 'px, ' + startY + 'px) scale(0.5)';
    bag.style.opacity = '1';

    document.documentElement.appendChild(bag);
    void bag.offsetWidth;

    var endX = cartRect.left + (cartRect.width / 2) - (bagSize / 2);
    var endY = cartRect.top + (cartRect.height / 2) - (bagSize / 2);

    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        bag.style.transition = 'transform 1.4s cubic-bezier(0.25, 1, 0.5, 1), opacity 1.2s ease-in-out';
        bag.style.transform = 'translate(' + endX + 'px, ' + endY + 'px) scale(0.2)';
        bag.style.opacity = '0.3';
      });
    });

    setTimeout(function() {
      if(bag.parentNode) bag.parentNode.removeChild(bag);
    }, 1450);
  }

  document.querySelectorAll('.fit11-btn-cart').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      if(btn.disabled || btn.classList.contains('loading')) return;
      playBagAnimation(btn);
    });
  });

  /* TICKER LOGIC */
  document.querySelectorAll('.fit11TickerWrapper').forEach(function(ticker) {
    var items = ticker.querySelectorAll('.fit11-ticker-item');
    if(items.length <= 1) return;
    var curTick = 0;
    setInterval(function() {
      curTick++;
      if (curTick >= items.length) {
        ticker.style.transition = 'none';
        ticker.style.transform = 'translateY(0)';
        curTick = 1;
        ticker.offsetHeight;
        ticker.style.transition = 'transform 0.6s ease-in-out';
      }
      ticker.style.transform = 'translateY(-' + (curTick * 34) + 'px)';
    }, 3000);
  });

/* CLICK TO COPY COUPON LOGIC */
window.fit11CopyCoupon = function(cardElement, code) {
  if(cardElement.classList.contains('expired')) return;
  if(!code) return;

  if (navigator.clipboard) {
    navigator.clipboard.writeText(code).catch(function(){});
  } else {
    var el = document.createElement('textarea');
    el.value = code; document.body.appendChild(el); el.select();
    try { document.execCommand('copy'); } catch(e) {}
    document.body.removeChild(el);
  }

  var hint = cardElement.querySelector('.fit11-copy-hint');
  if(hint) {
    var origHTML = hint.innerHTML;
    hint.innerHTML = '<i class="ti ti-check"></i> Code Copied!';
    hint.classList.add('success');

    setTimeout(function() {
      hint.innerHTML = origHTML;
      hint.classList.remove('success');
    }, 2000);
  }
};
</script>

<div id="fit11Lightbox" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.9); z-index:999999; justify-content:center; align-items:center;">
  <span style="position:absolute; top:20px; right:20px; color:white; font-size:40px; cursor:pointer;" onclick="document.getElementById('fit11Lightbox').style.display='none'">&times;</span>
  <img id="fit11LightboxImg" style="max-width:90%; max-height:90%; object-fit:contain;">
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  function enableDragScroll(selector) {
    document.querySelectorAll(selector).forEach(function(slider) {
      let isDown = false;
      let startX;
      let scrollLeft;

      slider.addEventListener('mousedown', function(e) {
        isDown = true;
        slider.style.cursor = 'grabbing';
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
      });
      slider.addEventListener('mouseleave', function() {
        isDown = false;
        slider.style.cursor = '';
      });
      slider.addEventListener('mouseup', function() {
        isDown = false;
        slider.style.cursor = '';
      });
      slider.addEventListener('mousemove', function(e) {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - slider.offsetLeft;
        const walk = (x - startX) * 2;
        slider.scrollLeft = scrollLeft - walk;
      });
    });
  }
  enableDragScroll('.fit11-slides, .fit11-variant-pills, .fit11-offers-scroll, .fit11-thumbs');
});
</script>

<div class="fit11-sticky-bar" id="fit11-sticky-bar-main">
  <button type="button" class="fit11-btn-cart" id="fit11StickyAddBtn" style="flex: 1; margin: 0 !important; background: #222 !important; color: #fff !important; border-radius: 6px; border: none; font-weight: 600; font-size: 14px; height: 50px !important; display: flex; align-items: center; justify-content: center; gap: 8px;" onclick="fit11StickyAddToCart()">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
    <span class="fit11-btn-text">ADD TO CART</span>
  </button>
  <button type="button" class="fit11-btn-cart" id="fit11StickyBuyBtn" style="flex: 1; margin: 0 !important; background: #ffdf00 !important; color: #000 !important; border-radius: 6px; border: none; font-weight: 700; font-size: 14px; height: 50px !important; display: flex; align-items: center; justify-content: center;" onclick="fit11StickyBuyNow(this)">
    <span class="fit11-btn-text">BUY NOW</span>
  </button>
</div>

<script>
  function fit11StickyAddToCart() {
    var comboBtn = document.getElementById('fit11ComboAddToCartBtn');
    if(comboBtn) comboBtn.click();
    else {
      var regularBtn = document.getElementById('fit11MainAddToCartBtnProd');
      if(regularBtn) regularBtn.click();
    }
  }
  function fit11StickyBuyNow(btn) {
    var comboBtn = document.getElementById('fit11ComboBuyNowBtn');
    if(comboBtn) comboBtn.click();
    else if(typeof window.fit11BuyNowRegular === 'function') {
      window.fit11BuyNowRegular(btn);
    }
  }

  (function() {
    var stickyBar = document.getElementById('fit11-sticky-bar-main');
    var target = document.querySelector('.fit11-main-buttons-container');
    if(stickyBar && target) {
      var observer = new IntersectionObserver(function(entries) {
        var entry = entries[0];
        // Show sticky bar only when the main buttons container is completely scrolled out of view upwards
        if (!entry.isIntersecting && entry.boundingClientRect.top < 0) {
          stickyBar.classList.add('fit11-is-visible');
        } else {
          stickyBar.classList.remove('fit11-is-visible');
        }
      }, { threshold: 0 });
      observer.observe(target);
    }
  })();
</script>

