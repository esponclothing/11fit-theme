                  <span class="fit11-option-name-label" style="font-weight: 500; font-size: 13px; text-transform: none; letter-spacing: normal; white-space: nowrap; overflow-x: auto; scrollbar-width: none; max-width: 100%; padding-bottom: 4px;">Selected Color - <span class="fit11-selected-color-label" style="font-weight: 700; color: var(--lux-text); text-transform: capitalize;">{{ option.selected_value }}</span></span>
                </div>
                <div class="fit11-variant-pills">
                  {% for value in option.values %}
                    <input type="radio"
                           id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}-mobile"
