      {% comment %} ── COLOR VARIANTS AS THUMBNAILS (MOBILE) ── {% endcomment %}
      {% unless product.has_only_default_variant %}
        {% for option in product.options_with_values %}
          {% assign option_name_lower = option.name | downcase %}
          {% if option_name_lower contains 'color' or option_name_lower contains 'colour' %}
            <div class="fit11-variant-selectors top-color-selector mobile-only-color" style="padding: 0 16px; margin-bottom: 0px; margin-top: 8px;">
              <div class="fit11-option-fieldset" role="group" style="border:none; padding:0; margin:0; min-width: 0; width: 100%;">
