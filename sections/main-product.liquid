          {% assign final_price_cents = combo_price | times: 100 %}
          {% assign compare_at_base = product.compare_at_price | default: product.price %}
          {% assign final_compare_at_cents = compare_at_base | times: combo_count %}
        {% else %}
          {% assign final_price_cents = product.price %}
          {% assign final_compare_at_cents = product.compare_at_price %}
        {% endif %}

