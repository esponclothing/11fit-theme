                           value="{{ value | escape }}"
                           {% if option.selected_value == value %}checked{% endif %}
                           class="fit11-variant-radio"
                           data-is-color="true">

                    <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}-mobile" class="fit11-variant-pill is-color" title="{{ value }}">
                      {% assign variant_image = null %}
                      {% for variant in product.variants %}
                        {% if variant.options contains value and variant.featured_image %}
                          {% assign variant_image = variant.featured_image %}
                          {% break %}
                        {% endif %}
                      {% endfor %}

                      <div class="fit11-color-swatch-wrap">
                        {% if variant_image != null %}
