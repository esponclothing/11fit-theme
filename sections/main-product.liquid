                            {% when 'navy-blue' %}{% assign css_color = '#000080' %}
                            {% when 'bottle-green' %}{% assign css_color = '#006A4E' %}
                            {% when 'light-baby-pink' %}{% assign css_color = '#F4C2C2' %}
                            {% when 'lavender' %}{% assign css_color = '#E6E6FA' %}
                            {% when 'baby-blue' %}{% assign css_color = '#89CFF0' %}
                            {% when 'flamingo' %}{% assign css_color = '#FC8EAC' %}
                            {% when 'jade' %}{% assign css_color = '#00A86B' %}
                            {% when 'off-white' %}{% assign css_color = '#FAF9F6' %}
                            {% when 'maroon' %}{% assign css_color = '#800000' %}
                            {% when 'white' %}{% assign css_color = '#FFFFFF' %}
                            {% when 'black' %}{% assign css_color = '#000000' %}
                            {% when 'red' %}{% assign css_color = '#FF0000' %}
