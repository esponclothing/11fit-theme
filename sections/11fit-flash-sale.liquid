{% comment %}
  ============================================================
  11FIT — trending-products.liquid (ELEGANT AUTO-SWIPER)
  Drop this file into: sections/trending-products.liquid
  ============================================================
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&display=swap">

<style>
  .11fit-trend-wrapper {
    background-color: {{ section.settings.bg_color }};
    padding: 60px 20px;
    font-family: 'Outfit', sans-serif;
    overflow: hidden;
    width: 100%;
    box-sizing: border-box;
    text-align: center;
  }
  
  .11fit-trend-wrapper * {
    box-sizing: border-box;
  }

  /* ── HEADER & TYPOGRAPHY ── */
  .11fit-trend-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 40px;
  }

  .11fit-trend-title {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    font-weight: 400;
    color: {{ section.settings.accent_color }};
    margin: 0 0 10px 0;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .11fit-trend-subtitle {
    font-size: 11px;
    font-weight: 500;
    color: {{ section.settings.accent_color }};
    margin: 0;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  /* ── CAROUSEL TRACK ── */
  .11fit-trend-carousel-wrap {
    max-width: 400px;
    margin: 0 auto;
    position: relative;
  }

  .11fit-trend-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    gap: 20px;
    padding-bottom: 10px;
  }

  .11fit-trend-track::-webkit-scrollbar {
    display: none;
  }

  /* ── PRODUCT CARD ── */
  .11fit-trend-card {
    flex: 0 0 100%;
    scroll-snap-align: center;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: opacity 0.3s ease;
  }

  .11fit-trend-img-wrap {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: #f8fafc;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .11fit-trend-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .11fit-trend-prod-title {
    font-family: 'Playfair Display', serif;
    color: {{ section.settings.accent_color }};
    font-size: 20px;
    font-weight: 400;
    line-height: 1.3;
    margin: 0 0 12px 0;
    padding: 0 10px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .11fit-trend-price {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #111;
  }

  /* ── DOTS PAGINATION ── */
  .11fit-trend-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 24px;
  }

  .fit11-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #cbd5e1;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .fit11-dot.active {
    background: {{ section.settings.accent_color }};
    transform: scale(1.2);
  }

  /* ── MOBILE OVERRIDES ── */
  @media (max-width: 767px) {
    .11fit-trend-wrapper { padding: 40px 16px; }
    .11fit-trend-title { font-size: 28px; }
    .11fit-trend-prod-title { font-size: 18px; }
  }

  /* ── PC REFINEMENTS ── */
  @media (min-width: 768px) {
    .11fit-trend-wrapper {
      background: radial-gradient(circle at top, #ffffff 0%, {{ section.settings.bg_color }} 100%);
      padding: 80px 20px;
    }
    .11fit-trend-carousel-wrap {
      max-width: 1200px;
    }
    .11fit-trend-card {
      flex: 0 0 calc(25% - 15px); /* 4 items with 20px gap */
      transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.4s ease;
      border-radius: 12px;
      padding-bottom: 20px;
    }
    .11fit-trend-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0,0,0,0.04);
      background: #ffffff;
    }
    .11fit-trend-img-wrap img {
      transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .11fit-trend-card:hover .11fit-trend-img-wrap img {
      transform: scale(1.06);
    }
  }
</style>

<div class="11fit-trend-wrapper pc-reveal" id="11fitTrendWrapper-{{ section.id }}" data-speed="{{ section.settings.autoplay_speed | times: 1000 }}">
  
  <div class="11fit-trend-header pc-reveal">
    <h2 class="11fit-trend-title">{{ section.settings.heading }}</h2>
    <p class="11fit-trend-subtitle">{{ section.settings.subheading }}</p>
  </div>

  <div class="11fit-trend-carousel-wrap">
    <div class="11fit-trend-track pc-reveal-stagger" id="11fitTrendTrack-{{ section.id }}">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        
        <a href="{{ product.url | default: '#' }}" class="11fit-trend-card" {{ block.shopify_attributes }}>
          <div class="11fit-trend-img-wrap">
            {% if product != blank and product.featured_image %}
              <img src="{{ product.featured_image | img_url: '600x750', crop: 'center' }}" alt="{{ product.title | escape }}" loading="lazy">
            {% else %}
              <span style="font-size:12px; color:#94a3b8; font-family:'Outfit', sans-serif;">Select Product</span>
            {% endif %}
          </div>

          <h3 class="11fit-trend-prod-title">
            {{ product.title | default: 'ESPON NS Terry Lycra 30% Active Shorts' }}
          </h3>
          
          <div class="11fit-trend-price">
            {{ product.price | default: 199900 | money_without_trailing_zeros }}
          </div>
        </a>
      {% endfor %}
    </div>

    {% if section.blocks.size > 1 %}
      <div class="11fit-trend-dots" id="11fitTrendDots-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="fit11-dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}"></div>
        {% endfor %}
      </div>
    {% endif %}
  </div>

</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    
    // --- CAROUSEL AUTO-SWIPE & DOTS SYNC LOGIC ---
    const track = document.getElementById('11fitTrendTrack-{{ section.id }}');
    const dotsWrap = document.getElementById('11fitTrendDots-{{ section.id }}');
    const wrapper = document.getElementById('11fitTrendWrapper-{{ section.id }}');
    
    if (!track) return;

    const dots = dotsWrap ? dotsWrap.querySelectorAll('.fit11-dot') : [];
    const totalItems = dots.length;
    let currentIndex = 0;
    
    const speed = parseInt(wrapper.getAttribute('data-speed')) || 3000;
    let autoPlayInterval;

    // 1. Sync dots when user manually scrolls
    track.addEventListener('scroll', function() {
      if(totalItems === 0) return;
      const scrollPos = track.scrollLeft;
      const cardWidth = track.clientWidth;
      const newIndex = Math.round(scrollPos / cardWidth);

      if (newIndex !== currentIndex && newIndex >= 0 && newIndex < totalItems) {
        dots[currentIndex].classList.remove('active');
        currentIndex = newIndex;
        dots[currentIndex].classList.add('active');
      }
    });

    // 2. Click a dot to jump to that product
    if(totalItems > 0) {
      dots.forEach((dot, i) => {
        dot.addEventListener('click', function() {
          const cardWidth = track.clientWidth;
          track.scrollTo({ left: cardWidth * i, behavior: 'smooth' });
        });
      });
    }

    // 3. Auto-swipe function
    function scrollToNextItem() {
      const cardWidth = track.clientWidth;
      const maxScroll = track.scrollWidth - track.clientWidth;

      // Reset to beginning if at the end
      if (track.scrollLeft >= maxScroll - 10) {
        track.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        track.scrollBy({ left: cardWidth, behavior: 'smooth' });
      }
    }

    function startAutoPlay() {
      if(totalItems > 1) {
        autoPlayInterval = setInterval(scrollToNextItem, speed);
      }
    }

    function stopAutoPlay() {
      clearInterval(autoPlayInterval);
    }

    // 4. Pause swiping when user interacts
    wrapper.addEventListener('touchstart', stopAutoPlay, {passive: true});
    wrapper.addEventListener('touchend', startAutoPlay, {passive: true});
    wrapper.addEventListener('mouseenter', stopAutoPlay);
    wrapper.addEventListener('mouseleave', startAutoPlay);

    // Start immediately
    startAutoPlay();
  });
</script>

{% schema %}
{
  "name": "Trending Products",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Luxury Accent Color",
      "default": "#9A7B4F",
      "info": "Used for headings and product titles."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "TRENDING PRODUCTS"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "DISCOVER OUR BESTSELLERS"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "sec",
      "label": "Auto-Swipe Speed",
      "default": 3,
      "info": "How fast the products scroll automatically."
    }
  ],
  "blocks": [
    {
      "type": "product_item",
      "name": "Trending Product",
      "limit": 8,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trending Products (Elegant)",
      "blocks": [
        { "type": "product_item" },
        { "type": "product_item" },
        { "type": "product_item" }
      ]
    }
  ]
}
{% endschema %}