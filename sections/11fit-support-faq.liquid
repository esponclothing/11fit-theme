        { "type": "faq_item", "settings": { "question": "Which courier services do you use?", "answer": "We provide doorstep delivery across India using trusted courier partners including Blue Dart, DTDC, Delhivery, and Xpressbees — ensuring your gear arrives quickly and safely." } },
        { "type": "faq_item", "settings": { "question": "What is your return and refund policy?", "answer": "We want you to train in gear you love! If there is a sizing issue or you are not completely satisfied, we offer a hassle-free return and refund within 7 days of receiving your order." } },
