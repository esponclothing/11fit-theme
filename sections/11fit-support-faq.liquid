        { "type": "faq_item", "settings": { "question": "Is free shipping available?", "answer": "Yes! We offer free shipping on all orders above ₹499. Orders below this amount will have a nominal delivery charge applied at checkout." } }
      ]
    }
  ]
}
{% endschema %}