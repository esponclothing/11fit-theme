    "custom_liquid_BRkQHE": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{% if template.name == 'product' and product.metafields.custom.floating_video != blank %}\n\n\n<style>\n\n/* =========================\n\n   FLOATING VIDEO BUTTON\n\n   ========================= */\n\n.floating-video {\n\n  position: fixed;\n\n  bottom: 96px;\n\n  right: 16px;\n\n  width: 90px;\n\n  aspect-ratio: 9 / 16;\n\n  background: #000;\n\n  border-radius: 12px;\n\n  overflow: hidden;\n\n  z-index: 60;\n\n  cursor: pointer;\n\n  box-shadow: 0 10px 24px rgba(0,0,0,0.25);\n\n}\n\n\n.floating-video video {\n\n  width: 100%;\n\n  height: 100%;\n\n  object-fit: cover;\n\n}\n\n\n/* =========================\n\n   POPUP OVERLAY\n\n   ========================= */\n\n.video-popup-overlay {\n\n\n  position: fixed;\n\n  inset: 0;\n\n  background: rgba(0,0,0,0.6);\n\n  display: none;\n\n  align-items: center;\n\n  justify-content: center;\n\n  z-index: 9999;\n\n}\n\n\n/* Lock scroll */\n\nhtml.video-popup-open,\n\nbody.video-popup-open {\n\n  overflow: hidden;\n\n  height: 100%;\n\n}\n\n\n/* =========================\n\n   POPUP CONTAINER\n\n   ========================= */\n\n.video-popup {\n\ntop:45px;\n\noverflow-y: auto;\n\n  width: auto;\n\n  max-width: 350px;\n\n  max-height: 85vh;\n\n  background: #fff;\n\n  border-radius: 14px;\n\n  overflow: hidden;\n\n  position: relative;\n\n  box-shadow: 0 20px 40px rgba(0,0,0,0.35);\n\n}\n\n\n/* =========================\n\n   VIDEO (ADAPT TO RATIO)\n\n   ========================= */\n\n.video-popup video {\n\n  display: block;\n\n  width: 250px;\n\n  height: 280px;\n\n \n\n  object-fit: contain;\n\n  background: #000;\n\n}\n\n\n/* =========================\n\n   CLOSE BUTTON\n\n   ========================= */\n\n.video-popup-close {\n\n  position: absolute;\n\n  top: 10px;\n\n  right: 12px;\n\n  width: 32px;\n\n  height: 32px;\n\n  border-radius: 50%;\n\n  background: rgba(0,0,0,0.6);\n\n  color: #fff;\n\n  font-size: 18px;\n\n  line-height: 32px;\n\n  text-align: center;\n\n  cursor: pointer;\n\n  z-index: 2;\n\n}\n\n\n/* =========================\n\n   CONTROLS\n\n   ========================= */\n\n.video-popup-controls {\n\n  padding: 12px;\n\n  display: flex;\n\n  flex-direction: column;\n\n  gap: 10px;\n\n}\n\n\n.video-popup-controls select,\n\n.video-popup-controls input {\n\n  width: 100%;\n\n  padding: 10px;\n\n  font-size: 14px;\n\n  border: 1px solid #e5e5e5;\n\n  border-radius: 6px;\n\n}\n\n\n/* =========================\n\n   ADD TO CART\n\n   ========================= */\n\n.video-popup-atc button {\n\n  width: 100%;\n\n  padding: 14px;\n\n  background: #000;\n\n  color: #fff;\n\n  font-size: 15px;\n\n  font-weight: 600;\n\n  border: none;\n\n  border-radius: 8px;\n\n  cursor: pointer;\n\n}\n\n\n.video-popup-atc button:hover {\n\n  opacity: 0.9;\n\n}\n\n\n/* =========================\n\n   MOBILE\n\n   ========================= */\n\n@media (max-width: 768px) {\n\n  .floating-video {\n\n    bottom: 84px;\n\n    width: 80px;\n\n  }\n\n}\n\n</style>\n\n\n<!-- Floating Video Button -->\n\n<div class=\"floating-video\" id=\"floatingVideo\">\n\n  <video autoplay muted loop playsinline>\n\n    <source src=\"{{ product.metafields.custom.floating_video | file_url }}\" type=\"video/mp4\">\n\n  </video>\n\n</div>\n\n\n<!-- Popup -->\n\n<div class=\"video-popup-overlay\" id=\"videoPopup\">\n\n  <div class=\"video-popup\">\n\n    <span class=\"video-popup-close\" id=\"closePopup\">✕</span>\n\n\n    <video autoplay muted loop playsinline>\n\n      <source src=\"{{ product.metafields.custom.floating_video | file_url }}\" type=\"video/mp4\">\n\n    </video>\n\n\n    <div class=\"video-popup-controls\">\n\n\n      {% if product.variants.size > 1 %}\n\n      <select id=\"popupVariant\">\n\n        {% for variant in product.variants %}\n\n          <option value=\"{{ variant.id }}\">\n\n            {{ variant.title }}\n\n          </option>\n\n        {% endfor %}\n\n      </select>\n\n      {% else %}\n\n        <input type=\"hidden\" id=\"popupVariant\" value=\"{{ product.selected_or_first_available_variant.id }}\">\n\n      {% endif %}\n\n\n      <input type=\"number\" id=\"popupQty\" value=\"1\" min=\"1\">\n\n\n      <div class=\"video-popup-atc\">\n\n        <button id=\"popupAddToCart\">Add to Cart</button>\n\n      </div>\n\n\n\n    </div>\n\n\n  </div>\n\n</div>\n\n\n<script>\n\n(function () {\n\n\n  var floatingVideo = document.getElementById('floatingVideo');\n\n  var popup = document.getElementById('videoPopup');\n\n  var closeBtn = document.getElementById('closePopup');\n\n  var addToCartBtn = document.getElementById('popupAddToCart');\n\n  var variantSelect = document.getElementById('popupVariant');\n\n  var qtyInput = document.getElementById('popupQty');\n\n\n  if (!floatingVideo || !popup) return;\n\n\n  floatingVideo.addEventListener('click', function () {\n\n    popup.style.display = 'flex';\n\n    document.documentElement.classList.add('video-popup-open');\n\n    document.body.classList.add('video-popup-open');\n\n  });\n\n\n  closeBtn.addEventListener('click', closePopup);\n\n  popup.addEventListener('click', function (e) {\n\n    if (e.target === popup) closePopup();\n\n  });\n\n\n  function closePopup() {\n\n    popup.style.display = 'none';\n\n    document.documentElement.classList.remove('video-popup-open');\n\n    document.body.classList.remove('video-popup-open');\n\n  }\n\n\n  addToCartBtn.addEventListener('click', function () {\n\n    fetch('/cart/add.js', {\n\n      method: 'POST',\n\n      headers: { 'Content-Type': 'application/json' },\n\n      body: JSON.stringify({\n\n        id: variantSelect.value,\n\n        quantity: parseInt(qtyInput.value, 10) || 1\n\n      })\n\n    }).then(function () {\n\n      window.location.reload();\n\n    });\n\n  });\n\n\n})();\n\n</script>\n\n\n{% endif %}",
        "color_scheme": "",
        "padding_top": 40,
        "padding_bottom": 52
      }
    }
